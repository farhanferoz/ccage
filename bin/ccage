#!/usr/bin/env bash
# ccage — CLI dispatcher.
#
# Installed as ~/.local/bin/ccage (or wherever install.sh's --prefix points).
# Sources share/ccage-handoff.sh from the install layout: the dispatcher and
# the libraries ship together, with $CCAGE_LIB pointing at the lib dir.
#
# Subcommands:
#   handoff      — produce a Markdown brief from a session JSONL
#   doctor       — backfill session-docs hooks + report a RESUME/memory worklist
#   enable-mcp   — opt the current project into an MCP server (project .mcp.json)
#   disable-mcp  — remove an MCP server from the current project's .mcp.json
#   -h --help    — this message

# Resolve install layout. Two modes:
#   1. Running from the source tree (development): bin/ccage → ../share/
#   2. Running from an install: $PREFIX/bin/ccage → $PREFIX/share/ccage/
# We try the source-tree layout first, then fall back to a standard share dir.
_ccage_resolve_lib() {
    local self="${BASH_SOURCE[0]}"
    # follow symlinks
    while [ -L "$self" ]; do
        local target
        target=$(readlink "$self")
        case "$target" in
            /*) self="$target" ;;
            *)  self="$(dirname "$self")/$target" ;;
        esac
    done
    local bin_dir lib_candidate
    bin_dir=$(cd "$(dirname "$self")" && pwd)

    for lib_candidate in \
        "${CCAGE_LIB:-}" \
        "$bin_dir/../share" \
        "$bin_dir/../share/ccage"
    do
        [ -n "$lib_candidate" ] || continue
        if [ -f "$lib_candidate/ccage-handoff.sh" ]; then
            (cd "$lib_candidate" && pwd)
            return 0
        fi
    done
    # shellcheck disable=SC2016  # $CCAGE_LIB is literal text in the error message
    printf 'ccage: cannot locate share/ccage-handoff.sh — set $CCAGE_LIB?\n' >&2
    return 2
}

# Source the isolation lib (and a user's overrides companion) so subcommands can
# reuse ccage's real cage-keying rule. A plain shell has no CLAUDE_CONFIG_DIR —
# the claude() wrapper exports it with `local -x` so it never leaks — so without
# this, `ccage handoff` had no way to find the cage owning the current project.
#
# The overrides file is what an interactive shell loads after the lib; it is
# also where _CCAGE_OVERRIDE_ACTIVE=1 is set, so skipping it would silently
# ignore a user's _ccage_config_dir_override. Both are optional: absent, cage
# resolution falls back to scanning .owning_path markers.
_ccage_source_isolation() {
    local lib_dir="$1" iso rcd
    for iso in "$lib_dir/claude-isolation.sh" "$HOME/.bashrc.d/claude-isolation.sh" "$HOME/.zshrc.d/claude-isolation.sh"; do
        if [ -r "$iso" ]; then
            # shellcheck source=../share/claude-isolation.sh disable=SC1091
            . "$iso"
            break
        fi
    done
    for rcd in "$HOME/.bashrc.d" "$HOME/.zshrc.d"; do
        if [ -r "$rcd/claude-overrides.sh" ]; then
            # Output SUPPRESSED, unlike the isolation lib above. That lib is
            # ccage's own and verified side-effect-free; this one is the user's
            # and carries no such guarantee. An `echo` in it landed as the first
            # line of the brief — ahead of the `# Handoff:` heading — silently
            # corrupting a file whose whole purpose is to be pasted into a fresh
            # session. Function definitions still land; noise does not. The
            # subshell-free form is required (a subshell would discard the
            # definitions we are here to get), so `|| true` keeps a `set -e`
            # inside the user's file from killing the command.
            #
            # `|| true` guards the sourcing COMMAND only. `set -e`/`set -u` run
            # inside the file PERSIST in this shell afterwards and abort ccage at
            # the next non-zero command — cage resolution is a ladder whose
            # earlier rungs are expected to fail. Found on the macOS CI leg,
            # where resolution takes one rung more than on Linux and the whole
            # command exited non-zero with no output. Snapshot and restore.
            _ccage_rc_opts="$-"
            # shellcheck disable=SC1091  # user-supplied, may not exist
            { . "$rcd/claude-overrides.sh"; } >/dev/null 2>&1 || true
            case "$_ccage_rc_opts" in *e*) ;; *) set +e ;; esac
            case "$_ccage_rc_opts" in *u*) ;; *) set +u ;; esac
            unset _ccage_rc_opts
            break
        fi
    done
}

case "${1:-}" in
    handoff)
        shift
        CCAGE_LIB=$(_ccage_resolve_lib) || exit $?
        _ccage_source_isolation "$CCAGE_LIB"
        # shellcheck source=../share/ccage-handoff.sh disable=SC1091
        . "$CCAGE_LIB/ccage-handoff.sh"
        _ccage_handoff_main "$@"
        ;;
    doctor)
        shift
        CCAGE_LIB=$(_ccage_resolve_lib) || exit $?
        # shellcheck source=../share/ccage-doctor.sh disable=SC1091
        . "$CCAGE_LIB/ccage-doctor.sh"
        _ccage_doctor_main "$@"
        ;;
    enable-mcp)
        shift
        CCAGE_LIB=$(_ccage_resolve_lib) || exit $?
        # shellcheck source=../share/ccage-enable-mcp.sh disable=SC1091
        . "$CCAGE_LIB/ccage-enable-mcp.sh"
        _ccage_enable_mcp_main "$@"
        ;;
    disable-mcp)
        shift
        CCAGE_LIB=$(_ccage_resolve_lib) || exit $?
        # shellcheck source=../share/ccage-enable-mcp.sh disable=SC1091
        . "$CCAGE_LIB/ccage-enable-mcp.sh"
        _ccage_disable_mcp_main "$@"
        ;;
    -h|--help|"")
        cat <<EOF
Usage: ccage <command> [args]

Commands:
  handoff       Produce a Markdown brief from a Claude Code session JSONL.
  doctor        Backfill the session-docs hooks block into every cage and report
                a worklist of repos needing /checkpoint (RESUME bloat / messy memory).
  enable-mcp    Opt the current project into an MCP server (writes a project-scoped
                .mcp.json — never a cage's .claude.json). MCP stays per-project by
                design; agents/skills are the globally shared part.
  disable-mcp   Remove an MCP server from the current project's .mcp.json.

Env:
  CCAGE_LIB           Override library directory (default: \$(dirname \$0)/../share).
  CCAGE_HANDOFF_DIR   Where handoff briefs are written. Default:
                      \${XDG_DATA_HOME:-~/.local/share}/ccage/handoffs.

ccage handoff -h / ccage doctor -h / ccage enable-mcp -h for subcommand help.
EOF
        ;;
    *)
        printf 'ccage: unknown subcommand: %s\nusage: ccage handoff [...]\n' "$1" >&2
        exit 2
        ;;
esac
