#!/usr/bin/env python3
# ccage-auto — autonomous context manager for a single long-lived Claude session.
#
# Launches a Claude Code session through ccage's normal `claude` shell wrapper,
# but interposes a pseudo-terminal so an in-process watcher can (a) measure the
# session's real context occupancy by reading its transcript JSONL and (b) drive
# the checkpoint -> clear -> resume loop with no human present.
#
# The split of labour:
#   - MEASURE  the watcher reads exact per-turn token usage from the transcript
#              (input + cache_read + cache_creation of the latest assistant turn);
#              no LLM, no estimation, no API calls.
#   - DECIDE   a tiny state machine compares occupancy to a soft and a hard
#              threshold.
#   - DRIVE    at the soft threshold it types a plain-text nudge so the model
#              itself runs the checkpoint skill at a clean breakpoint; once the
#              checkpoint is confirmed on disk it types `/clear` (the one thing
#              the model cannot do for itself) and then a short resume nudge.
#
# Injection is just writing bytes to the pty master fd — identical to a human
# typing — so it costs nothing and needs no tmux. The only model work triggered
# is the checkpoint + resume the user wanted anyway, which is far cheaper than
# letting the window grow to auto-compact.
#
# Enabled by default. Disable per-launch with `--no-autock` or CCAGE_AUTOCK=0;
# when disabled this is a transparent pass-through to the normal `claude`.
#
# Usage:
#   ccage-auto [auto-flags] [-- ] [claude args...]
#   ccage-auto --status            # print resolved paths + current occupancy, exit
#
# Control-plane subcommands (mutate the live control file for cwd, then exit
# without launching — the /checkpoint-threshold skill uses these to retune an
# ALREADY-RUNNING watcher). Recognised anywhere in argv, not just first — a
# user alias can prepend other flags (e.g. `ccage-auto-yolo` expanding to
# `--dangerously-skip-permissions --set soft=40`); whatever precedes the
# control token is dropped, since nothing is being launched:
#   ccage-auto --set soft=50 [hard=65]   # change thresholds mid-session
#   ccage-auto --pause / --resume        # suspend / re-enable auto-checkpointing
#   ccage-auto --reset                   # drop overrides, revert to launch values
#
# Auto-flags (consumed from the front; everything else is passed to claude):
#   --autock / --no-autock         force the watcher on/off (default: on)
#   --soft N                       soft threshold, percent       (default: 40)
#   --hard N                       hard threshold, percent       (default: soft + 20,
#                                  capped at 100; an explicit --hard always wins)
#   --window N                     force context window, tokens  (default: per-model)
#   --window-map 'sub=N,sub=N'     per-model windows by id substring
#   --poll N                       poll interval, seconds        (default: 12)
#   --weekly-floor N               stand down when remaining weekly capacity
#                                  drops to N percent            (default: off)
#   --status                       diagnostics only, do not launch
#
# Env equivalents (flags win): CCAGE_AUTOCK, CCAGE_AUTOCK_SOFT, CCAGE_AUTOCK_HARD,
#   CCAGE_AUTOCK_WINDOW, CCAGE_AUTOCK_WINDOWS, CCAGE_AUTOCK_POLL,
#   CCAGE_AUTOCK_SENTINEL, CCAGE_AUTOCK_HARD_INTERRUPT (1/0),
#   CCAGE_AUTOCK_NO_BYPASS_ACCEPT (1 = don't auto-accept the DSP bypass screen),
#   CCAGE_AUTOCK_EXEC (override the launched command; default `claude "$@"`),
#   CCAGE_AUTOCK_CHROME (1 = keep the Claude-in-Chrome handshake; default off,
#     i.e. launch adds --no-chrome — an autonomous session never drives a browser),
#   CCAGE_AUTOCK_INIT_PROMPT (type this + Enter at startup to auto-begin the task),
#   CCAGE_AUTOCK_INIT_DELAY (fallback ceiling, seconds, if the TUI ready-marker
#     never appears — normally the init prompt fires as soon as it does; default 20),
#   CCAGE_AUTOCK_READY_MARKER (string marking the TUI as rendered; default ❯),
#   CCAGE_AUTOCK_NUDGE (override the soft-nudge text; {pct}/{sentinel} substituted),
#   CCAGE_AUTOCK_HARD_NUDGE (override the hard-backstop nudge text; same substitutions),
#   CCAGE_AUTOCK_NUDGE_TIMEOUT (s before re-nudge if unconfirmed; default 600 — a
#     fallback alongside the re-nudge line at hard - 5%, whichever fires first),
#   CCAGE_AUTOCK_COOLDOWN (s to ignore thresholds after a reset; default 30),
#   CCAGE_AUTOCK_NO_ASK_GUARD (1 = don't register the AskUserQuestion guard),
#   CCAGE_AUTOCK_WEEKLY_FLOOR (remaining-% weekly-limit floor; see below).
#   CCAGE_SLOT is honoured for RESUME naming.
#
# Weekly-limit floor (opt-in, off by default). The context watcher manages the
# WINDOW; this manages the WEEK: an unattended run must not burn the account's
# seven-day capacity. Armed with --weekly-floor N / CCAGE_AUTOCK_WEEKLY_FLOOR=N
# (N = REMAINING percent, matching how you think about "how much week is
# left"). The sensor is the rate-limit state Claude Code passes to every
# statusline render, persisted by share/hooks/ccage-statusline-tee.sh into
# $CLAUDE_CONFIG_DIR/rate-limits-state.json (the flag exports the env var so
# the launched cage seeds that tee — see _ccage_seed_statusline_tee). Stages:
#   warn  (remaining <= floor+5): one advisory nudge — checkpoint soon.
#   floor (remaining <= floor):   force a checkpoint via the hard-backstop
#         machinery, append a stand-down note to RESUME.md, then STOP driving
#         the session (no /clear, no resume — safe to close). The checkpoint
#         IS the shutdown preparation; a mid-turn session is never killed.
# Sensor missing or older than 30 min → unknown → no action (logged once).
# Five-hour limits are recorded in the state file but not acted on (they
# recover within a run's horizon).
#
# A watched launch exports CCAGE_AUTONOMOUS=1 into the session and registers a
# per-run PreToolUse hook (share/hooks/autonomous_ask_guard.sh, via a generated
# `--settings` file) that blocks AskUserQuestion — a blocking question would
# stall an unattended run; the model is told to take the reversible default,
# log it in RESUME.md '### Decisions', and batch user-only questions for the
# end of the run. The disabled pass-through (--no-autock) sets none of this.
#
# Context windows differ by model and the transcript does NOT record which window
# a session has (a 1M and a 200K session log the same model id). The window is
# resolved per measurement (so a mid-session /model switch is picked up), most
# specific first: --window/CCAGE_AUTOCK_WINDOW force > per-model map > a [1m]
# marker in the model id > built-in small families (haiku) > a 1,000,000 default.
# The one case the data can't disambiguate — a 200K vs 1M variant of the SAME
# family — is yours to pin via --window-map / CCAGE_AUTOCK_WINDOWS (or --window).

import errno
import fcntl
import glob
import json
import os
import pty
import re
import select
import shlex
import signal
import subprocess
import sys
import termios
import threading
import time
import tty
from pathlib import Path


# ----------------------------------------------------------------------------
# Circuit breaker (subagent watchdog) — optional add-on. Its decision logic
# lives in lib/ (unit-tested); this script only wires it to a poll thread.
# Resolve lib/ next to the repo checkout OR an installed share/ccage tree, and
# degrade to a no-op if it is absent — the core auto-checkpointing must run even
# when the circuit-breaker library was not deployed.
# ----------------------------------------------------------------------------
def _load_ccb():
    here = os.path.dirname(os.path.realpath(__file__))
    for root in (os.path.join(here, ".."),                     # repo:      <root>/lib
                 os.path.join(here, "..", "share", "ccage")):   # installed: share/ccage/lib
        # Match the actual module file, not just any dir named "lib": in an
        # installed layout <prefix>/lib (e.g. ~/.local/lib, Python's user site)
        # exists and would otherwise shadow <prefix>/share/ccage/lib.
        if os.path.isfile(os.path.join(root, "lib", "subagent_watch.py")):
            root = os.path.realpath(root)
            if root not in sys.path:
                sys.path.insert(0, root)
            break
    try:
        from lib import ccb_types, subagent_watch
        return subagent_watch, ccb_types
    except Exception:
        return None, None


_ccb_watch, _ccb_types = _load_ccb()

# ----------------------------------------------------------------------------
# Configuration
# ----------------------------------------------------------------------------

SENTINEL_DEFAULT = "CHECKPOINTED"

# The transcript does NOT record the context window: a 1M session logs its model
# as plain "claude-opus-4-8", identical to a 200K session. So we cannot infer the
# window from the model id. Default to 1,000,000 (the long-context variant these
# autonomous sessions run on) and let --window / CCAGE_AUTOCK_WINDOW override it
# down to 200000 for a standard-context session. Defaulting HIGH is the safe
# failure: at worst the watcher defers to the hard threshold / auto-compact,
# whereas defaulting LOW would make it fire spuriously early.
WINDOW_1M = 1_000_000
WINDOW_STD = 200_000
ONE_M_MARKERS = ("[1m]", "-1m", "_1m")
BUILTIN_SMALL = ("haiku",)    # families that are unambiguously 200K
DEFAULT_WINDOW = WINDOW_1M    # fallback when the model is unknown / ambiguous

# Timing constants (seconds). Conservative; the fragile part is slash-command
# entry, so we settle generously before pressing Enter.
KEY_DELAY = 0.25        # pause between typing a line and submitting it
CLEAR_SETTLE = 3.0      # wait after /clear for the SessionStart hook + reload
COOLDOWN = 30.0         # ignore thresholds for this long after a reset
NUDGE_TIMEOUT = 600.0   # if no checkpoint confirmation, re-nudge / escalate (a
                        # fallback alongside the occupancy-anchored re-nudge —
                        # whichever fires first)
MAX_RENUDGE = 1         # soft re-nudges before escalating to the hard path

# Threshold derivation (decided contract, three rounds of clarification — do
# not re-derive): soft defaults to DEFAULT_SOFT; hard defaults to
# min(soft + HARD_MARGIN, 100) whenever it isn't explicitly named (an explicit
# --hard always wins); the re-nudge line sits at hard - RENUDGE_MARGIN.
# COLLISION_MARGIN is unrelated to that default — it's the emergency escape
# valve for an explicitly-conflicting soft/hard pair (soft >= hard), unchanged
# from before this contract existed.
DEFAULT_SOFT = 40.0
HARD_MARGIN = 20.0
RENUDGE_MARGIN = 5.0
COLLISION_MARGIN = 10.0

# Weekly-limit floor. The state file is written by ccage-statusline-tee.sh at
# the cage's config root on every statusline render; a reading older than the
# stale window is treated as no reading at all (a closed laptop must not
# trigger a stand-down off yesterday's number).
RATE_LIMITS_STATE = "rate-limits-state.json"
WEEKLY_WARN_MARGIN = 5.0        # warn stage fires at floor + this (remaining %)
WEEKLY_STALE_S = 30 * 60.0      # sensor readings older than this are unknown


def _truthy(v, default):
    if v is None:
        return default
    return str(v).strip().lower() not in ("0", "false", "no", "off", "")


def _num(v, default):
    try:
        return float(v)
    except (TypeError, ValueError):
        return default


def launch_command(cfg):
    """The shell command run_proxy hands to the interactive shell.
    CCAGE_AUTOCK_EXEC wins verbatim (a custom launcher owns its own flags);
    otherwise `claude`, with --no-chrome unless CCAGE_AUTOCK_CHROME opts back in.
    The disabled pass-through does NOT use this — it stays a transparent `claude`."""
    exec_override = os.environ.get("CCAGE_AUTOCK_EXEC")
    if exec_override:
        return exec_override
    return 'claude "$@"' if cfg.chrome else 'claude --no-chrome "$@"'


def ask_guard_path():
    """Locate autonomous_ask_guard.sh: the copy in this script's own tree first
    (a checkout — keeps tests hermetic even when ccage is also installed), then
    the fixed hooks path install.sh deploys to."""
    here = os.path.dirname(os.path.abspath(__file__))
    for cand in (
        os.path.join(here, "..", "share", "hooks", "autonomous_ask_guard.sh"),
        os.path.join(os.path.expanduser("~"), ".claude", "hooks",
                     "autonomous_ask_guard.sh"),
    ):
        if os.path.isfile(cand):
            return os.path.abspath(cand)
    return None


def write_guard_settings(sdir):
    """Write the per-run settings file registering the AskUserQuestion guard,
    and return its path (None if the hook script can't be found). Passed to the
    launched session via `claude --settings <file>` — the registration lives and
    dies with the run; no cage settings.json is ever touched. The hook itself is
    armed by the CCAGE_AUTONOMOUS marker, so a stale file is inert."""
    guard = ask_guard_path()
    if not guard:
        return None
    os.makedirs(sdir, exist_ok=True)
    path = os.path.join(sdir, "autonomous-settings.json")
    payload = {"hooks": {"PreToolUse": [{
        "matcher": "AskUserQuestion",
        "hooks": [{"type": "command", "command": "bash %s" % shlex.quote(guard)}],
    }]}}
    with open(path, "w") as f:
        json.dump(payload, f, indent=2)
        f.write("\n")
    return path


class Config:
    def __init__(self, args):
        self.enabled = _truthy(os.environ.get("CCAGE_AUTOCK"), True)
        self.soft = _num(os.environ.get("CCAGE_AUTOCK_SOFT"), DEFAULT_SOFT)
        # hard has no flat default: None means "derive from soft" (validate()
        # -> clamp_thresholds does the min(soft + HARD_MARGIN, 100) math).
        # hard_explicit tracks whether the user actually named a value, here or
        # via --hard below, so "explicit --hard wins" can be honoured even
        # after soft changes later (e.g. a live --set that only touches soft).
        self.hard = _num(os.environ.get("CCAGE_AUTOCK_HARD"), None)
        self.hard_explicit = self.hard is not None
        self.window = int(_num(os.environ.get("CCAGE_AUTOCK_WINDOW"), 0)) or None
        self.windows = parse_window_map(os.environ.get("CCAGE_AUTOCK_WINDOWS"))
        self.poll = _num(os.environ.get("CCAGE_AUTOCK_POLL"), 12.0)
        self.sentinel = os.environ.get("CCAGE_AUTOCK_SENTINEL") or SENTINEL_DEFAULT
        self.hard_interrupt = _truthy(os.environ.get("CCAGE_AUTOCK_HARD_INTERRUPT"), True)
        self.nudge_timeout = _num(os.environ.get("CCAGE_AUTOCK_NUDGE_TIMEOUT"), NUDGE_TIMEOUT)
        self.cooldown = _num(os.environ.get("CCAGE_AUTOCK_COOLDOWN"), COOLDOWN)
        # Weekly-limit floor, as REMAINING percent. 0 / unset / garbage = off.
        self.weekly_floor = _num(os.environ.get("CCAGE_AUTOCK_WEEKLY_FLOOR"), 0.0)
        # Autonomous kickoff: type this prompt + Enter once at startup so an
        # unattended session actually begins its task (a prompt passed as a CLI
        # arg only pre-fills the TUI input box; nobody is there to press Enter).
        self.init_prompt = os.environ.get("CCAGE_AUTOCK_INIT_PROMPT")
        # init_delay is now a FALLBACK CEILING: the kickoff normally fires as
        # soon as the TUI ready-marker is seen (measured 5–7s); only if the
        # marker never appears by the ceiling do we type blind (old behavior).
        self.init_delay = _num(os.environ.get("CCAGE_AUTOCK_INIT_DELAY"), 20.0)
        # First occurrence of this string in the ANSI-stripped pty output marks
        # the TUI input box as rendered. ❯ is the input prompt char; menus also
        # use it as a selection caret, so the bypass-accept path invalidates it.
        self.ready_marker = (os.environ.get("CCAGE_AUTOCK_READY_MARKER") or "❯").encode("utf-8")
        # Override the soft-nudge text; {pct} and {sentinel} are substituted.
        self.nudge = os.environ.get("CCAGE_AUTOCK_NUDGE")
        # Override the hard-backstop nudge text (same substitutions).
        self.hard_nudge = os.environ.get("CCAGE_AUTOCK_HARD_NUDGE")
        # Skip the Claude-in-Chrome startup handshake by default: an autonomous
        # session never drives a browser, and the connect attempt costs startup
        # time. CCAGE_AUTOCK_CHROME=1 keeps chrome (also the escape hatch for a
        # CLI too old to know --no-chrome, which would otherwise exit at launch).
        self.chrome = _truthy(os.environ.get("CCAGE_AUTOCK_CHROME"), False)
        self.status_only = False
        self.claude_args = self._parse(args)

    def _parse(self, args):
        i = 0

        def take():
            """The value token after the current flag, or None if the flag was
            last on the line — so a dangling `--soft` falls back to its default
            instead of raising IndexError."""
            return args[i + 1] if i + 1 < len(args) else None

        # Scan the WHOLE line for ccage-auto's own flags, not just the prefix up
        # to the first token we don't recognise. A user alias prepends flags —
        # `ccage-auto-yolo` is `ccage-auto --dangerously-skip-permissions` — so
        # stopping at the first unknown token meant `ccage-auto-yolo --soft 45`
        # silently launched at the DEFAULT soft and handed `--soft 45` to
        # claude, which rejected it. Task 6 fixed this for the control
        # subcommands (--set/--pause/...); it applies just as much to the launch
        # flags. Everything unrecognised still goes to claude in order, and a
        # literal `--` still ends ccage-auto's claim on the line entirely.
        claude_args = []
        while i < len(args):
            a = args[i]
            if a == "--":
                claude_args.extend(args[i + 1:])
                return claude_args
            elif a == "--autock":
                self.enabled = True
            elif a == "--no-autock":
                self.enabled = False
            elif a == "--status":
                self.status_only = True
            elif a == "--soft":
                self.soft = _num(take(), self.soft)
                i += 1
            elif a == "--hard":
                v = _num(take(), None)
                if v is not None:
                    self.hard = v
                    self.hard_explicit = True
                i += 1
            elif a == "--window":
                self.window = int(_num(take(), self.window or 0)) or None
                i += 1
            elif a == "--window-map":
                self.windows.update(parse_window_map(take()))
                i += 1
            elif a == "--poll":
                self.poll = _num(take(), self.poll)
                i += 1
            elif a == "--weekly-floor":
                self.weekly_floor = _num(take(), self.weekly_floor)
                i += 1
            else:
                # Not ours: hand it to claude, in order, and keep scanning for
                # our own flags further along the line. A ccage-auto-shaped
                # flag that's merely misspelled (--hardd, --softish, a --set
                # that reached here instead of being intercepted in main())
                # would otherwise vanish silently into claude's argv — warn so
                # the mistake is visible. Prefix match (--set*/--soft*/--hard*),
                # not a word-boundary regex: the typo shape we care about is
                # "extra trailing characters", which a \b anchor would miss (no
                # boundary between two word characters).
                if a.startswith(("--set", "--soft", "--hard")):
                    sys.stderr.write(
                        "[ccage-auto] warning: '%s' looks like a ccage-auto "
                        "flag but wasn't recognised — forwarding it to claude "
                        "verbatim; check the spelling\n" % a)
                claude_args.append(a)
            i += 1
        return claude_args

    def window_for(self, model):
        """Resolve the context window for a model id, most specific first:
        global override -> per-model map -> [1m] marker in the id -> built-in
        small family (haiku) -> default. Called per measurement, so a mid-session
        /model switch re-resolves the window automatically."""
        if self.window:
            return self.window
        if model:
            for key, win in self.windows.items():
                if key in model:
                    return win
            if any(m in model for m in ONE_M_MARKERS):
                return WINDOW_1M
            if any(s in model for s in BUILTIN_SMALL):
                return WINDOW_STD
        return DEFAULT_WINDOW

    def validate(self):
        """Clamp/derive thresholds; return human-readable warnings."""
        self.soft, self.hard, self.renudge, warns = clamp_thresholds(
            self.soft, self.hard if self.hard_explicit else None)
        # Weekly floor: 0 is the documented "off"; anything else must be a
        # sane remaining-percent. Disabling (not clamping) on garbage is the
        # safe failure — a floor the user never chose must not stop a run.
        if self.weekly_floor and not (0 < self.weekly_floor < 100):
            warns.append("weekly floor %.0f out of range (0,100); disabling"
                         % self.weekly_floor)
            self.weekly_floor = 0.0
        return warns


def clamp_thresholds(soft, hard):
    """Clamp/derive a (soft, hard) threshold pair; return
    (soft, hard, renudge, warnings).

    `soft=None` means "use DEFAULT_SOFT". `hard=None` means "not explicitly
    named — derive it from soft": `min(soft + HARD_MARGIN, 100)`, per the
    decided contract (explicit --hard always wins over that default). The
    re-nudge line is `hard - RENUDGE_MARGIN`, floored at soft so a very tight
    soft/hard pair can never push it below soft.

    Shared by Config.validate (launch flags/env), the `--set` control
    command, and the watcher's live control-file re-read, so the exact same
    rules apply everywhere — change it once, all three paths follow.
    """
    warns = []
    if soft is None:
        soft = DEFAULT_SOFT
    if not (0 < soft < 100):
        warns.append("soft=%.0f out of range (0,100); using %.0f" % (soft, DEFAULT_SOFT))
        soft = DEFAULT_SOFT
    if hard is not None and not (0 < hard <= 100):
        warns.append("hard=%.0f out of range (0,100]; deriving from soft instead" % hard)
        hard = None
    if hard is None:
        hard = min(100.0, soft + HARD_MARGIN)
        if hard >= 100.0:
            warns.append(
                "derived hard backstop hit the 100%% cap (soft %.0f%% + %.0f%%) "
                "— a backstop at a full window is too late to be useful; set "
                "--hard explicitly if that's not what you want"
                % (soft, HARD_MARGIN))
    if soft >= hard:
        new_hard = min(100.0, soft + COLLISION_MARGIN)   # cap at 100, never <= soft
        warns.append("soft (%.0f%%) >= hard (%.0f%%); raising hard to %.0f%%"
                     % (soft, hard, new_hard))
        hard = new_hard
    renudge = max(soft, hard - RENUDGE_MARGIN)
    return soft, hard, renudge, warns


# ----------------------------------------------------------------------------
# Locating the cage transcript
# ----------------------------------------------------------------------------

def cwd_slug(path):
    """Claude's project-dir slug: every non-alphanumeric cwd char becomes '-'.

    Not just '/' — '_' and '.' convert too (verified against real projects/
    dirs). Getting this wrong means watching an empty dir and never firing.
    """
    return re.sub(r"[^A-Za-z0-9]", "-", path)


def slot_suffix():
    """Mirror claude-isolation.sh's CCAGE_SLOT validation for RESUME naming."""
    slot = os.environ.get("CCAGE_SLOT", "")
    if slot and re.fullmatch(r"[A-Za-z0-9_-]+", slot):
        return "." + slot
    return ""


def resolve_config_dir(cwd):
    """Return the cage's CLAUDE_CONFIG_DIR for this cwd.

    Faithfulness matters (a companion override file can change the choice), so we
    ask ccage's own shell function first via the user's interactive shell, then
    fall back to sourcing the library directly, then to a pure-Python replica of
    the default naming (sans the rare collision hash)."""
    shell = os.environ.get("SHELL", "/bin/bash")

    # 0. Fast path: inside a cage, CLAUDE_CONFIG_DIR is already exported into every
    #    subprocess (the wrapper sets it for the launched session), so a nested
    #    `ccage-auto --status` invoked from the session's own Bash — the common
    #    case for the /checkpoint-threshold skill — inherits the authoritative
    #    value. Using it directly skips the ~2s interactive-shell resolution
    #    below (which sources the full .bashrc, conda init and all). It is unset
    #    when ccage-auto is the launcher (the watcher resolves the dir at startup
    #    before it launches claude), so the shell/replica fallbacks still apply
    #    there — where the override-faithful interactive path matters.
    cc = os.environ.get("CLAUDE_CONFIG_DIR")
    if cc:
        return cc

    # 1. Ask the real function through an interactive shell (sees .bashrc + overrides).
    try:
        out = subprocess.run(
            [shell, "-ic", '_ccage_config_dir_for "$PWD" 2>/dev/null'],
            cwd=cwd, capture_output=True, text=True, timeout=15,
        ).stdout.strip()
        if out:
            return out.splitlines()[-1].strip()
    except Exception:
        pass

    # 2. Source the shipped library directly (no interactive init).
    lib = library_path()
    if lib:
        try:
            out = subprocess.run(
                [shell, "-c", f'. {shlex.quote(lib)}; _ccage_config_dir_for "$PWD"'],
                cwd=cwd, capture_output=True, text=True, timeout=15,
            ).stdout.strip()
            if out:
                return out.splitlines()[-1].strip()
        except Exception:
            pass

    # 3. Pure-Python replica of the default scheme.
    root = os.environ.get("CCAGE_ROOT", os.path.expanduser("~"))
    prefix = os.environ.get("CCAGE_PREFIX", ".claude-")
    base = os.path.basename(cwd.rstrip("/")) or "root"
    cand = os.path.join(root, prefix + base)
    slot = os.environ.get("CCAGE_SLOT", "")
    if slot and re.fullmatch(r"[A-Za-z0-9_-]+", slot):
        cand += "--" + slot
    return cand


def library_path():
    """share/claude-isolation.sh, resolved relative to this script or $CCAGE_LIB."""
    candidates = []
    if os.environ.get("CCAGE_LIB"):
        candidates.append(os.environ["CCAGE_LIB"])
    here = os.path.dirname(os.path.realpath(__file__))
    candidates += [os.path.join(here, "..", "share"),
                   os.path.join(here, "..", "share", "ccage")]
    for c in candidates:
        p = os.path.join(c, "claude-isolation.sh")
        if os.path.isfile(p):
            return os.path.realpath(p)
    return None


def session_dir(config_dir, cwd):
    return os.path.join(config_dir, "projects", cwd_slug(cwd))


def active_jsonl(sdir, since=None):
    """Newest transcript in the session dir (handles /clear rotating the file).
    With `since`, only files modified at or after that time qualify — the
    watcher passes its start time so a *previous* session's transcript (newest
    by mtime until this session writes its own) can never supply a bogus
    occupancy reading at startup. Stats each candidate defensively: a file can
    be rotated/deleted between the glob and the stat, and an unguarded
    getmtime there would crash the watcher thread."""
    best, best_mtime = None, -1.0
    for f in glob.glob(os.path.join(sdir, "*.jsonl")):
        try:
            m = os.path.getmtime(f)
        except OSError:
            continue
        if since is not None and m < since:
            continue
        if m > best_mtime:
            best, best_mtime = f, m
    return best


# ----------------------------------------------------------------------------
# Reading context occupancy from the transcript
# ----------------------------------------------------------------------------

def _tail(path, maxbytes=512 * 1024):
    try:
        with open(path, "rb") as f:
            f.seek(0, os.SEEK_END)
            size = f.tell()
            start = max(0, size - maxbytes)
            f.seek(start)
            data = f.read()
    except OSError:
        return []
    if start > 0:
        nl = data.find(b"\n")
        data = data[nl + 1:] if nl >= 0 else b""
    return data.split(b"\n")


def latest_usage(path):
    """(tokens, model) for the most recent assistant turn, or (None, None).

    tokens = input + cache_read + cache_creation = the size of the prompt the
    model was just sent = current context occupancy."""
    for line in reversed(_tail(path)):
        line = line.strip()
        if not line or b'"assistant"' not in line:
            continue
        try:
            obj = json.loads(line)
        except ValueError:
            continue
        if obj.get("type") != "assistant":
            continue
        msg = obj.get("message") or {}
        usage = msg.get("usage") or {}
        if "input_tokens" not in usage:
            continue
        tokens = (
            (usage.get("input_tokens") or 0)
            + (usage.get("cache_read_input_tokens") or 0)
            + (usage.get("cache_creation_input_tokens") or 0)
        )
        return tokens, msg.get("model")
    return None, None


def parse_window_map(spec):
    """Parse a 'substr=tokens,substr=tokens' per-model window map into a dict.

    Keys are matched as substrings of the transcript model id (e.g.
    'haiku=200000,opus=1000000'). Malformed entries are ignored."""
    out = {}
    if not spec:
        return out
    for entry in spec.split(","):
        entry = entry.strip()
        if "=" not in entry:
            continue
        key, _, val = entry.partition("=")
        key = key.strip()
        try:
            n = int(val.strip())
        except ValueError:
            continue
        if key and n > 0:
            out[key] = n
    return out


def resume_mtime(cwd):
    """Newest mtime among RESUME.md / RESUME.<slot>.md, or 0."""
    best = 0.0
    for name in ("RESUME.md", "RESUME%s.md" % slot_suffix()):
        p = os.path.join(cwd, name)
        if os.path.isfile(p):
            best = max(best, os.path.getmtime(p))
    return best


def read_weekly_state(config_dir, now=None):
    """(remaining_pct, resets_at, age_s) from the cage's rate-limits state
    file, or (None, None, None) when the sensor is missing or malformed.

    Age is measured against the `ts` the tee stamped at write time, not file
    mtime, so a copied/restored file can't masquerade as fresh. Staleness is
    the CALLER's judgment — this only reports what the sensor said and when."""
    path = os.path.join(config_dir, RATE_LIMITS_STATE)
    try:
        with open(path) as f:
            obj = json.load(f)
    except (OSError, ValueError):
        return None, None, None
    if not isinstance(obj, dict):
        return None, None, None
    sd = obj.get("seven_day")
    if not isinstance(sd, dict):
        return None, None, None
    used = sd.get("used_percentage")
    ts = obj.get("ts")
    if not isinstance(used, (int, float)) or not isinstance(ts, (int, float)):
        return None, None, None
    age = (now if now is not None else time.time()) - ts
    return 100.0 - float(used), sd.get("resets_at"), age


# The completion marker written by `/checkpoint --final` (see the checkpoint
# skill). Deliberately a single fixed name, not slot-scoped: a coarse
# "the session's work is done, helpers may stand down" signal for this directory.
SESSION_DONE_MARKER = ".ccage-session-done"


def session_done_mtime(cwd):
    """mtime of the .ccage-session-done marker in cwd, or 0 if absent."""
    p = os.path.join(cwd, SESSION_DONE_MARKER)
    try:
        return os.path.getmtime(p)
    except OSError:
        return 0.0


# Liveness record for the ccage-auto watcher process itself: written when a
# watched launch starts, removed when it exits. resume_autoload.sh reads these
# (pid + start-time token) to decide whether SOME watcher is still depending
# on the marker files below before deleting them on a sibling session's
# startup — see plans/wave2-task6-findings.md for the incident that motivated
# this. Cheap and unambiguous by construction: a specific pid to `kill -0`,
# not a substring match over every process on the machine.
#
# ONE FILE PER WATCHER (`.ccage-autock.pid.<pid>`), not one shared file.
# Concurrent watchers in a single directory are an observed condition here, and
# a single shared record reopened the very bug this mechanism exists to close:
# watcher B starting in A's directory overwrote the record (last-writer-wins),
# and B's teardown then removed it unconditionally — leaving live watcher A
# unrepresented, so the next sibling session deleted the state A depends on.
# Per-pid files make both write and remove concurrent-safe by construction
# (each watcher only ever touches its own), and the hook's rule becomes "ANY
# live pid recorded here owns this directory's state", which is still an O(1)
# `kill -0` per file.
WATCHER_PIDFILE_BASE = ".ccage-autock.pid"
# One git-exclude pattern covers the per-pid records and the temp files below.
WATCHER_PIDFILE_GLOB = WATCHER_PIDFILE_BASE + "*"


def _parse_etime(s):
    """Parse ps's `[[DD-]hh:]mm:ss` elapsed-time format (the `etime` keyword)
    into total seconds, or None if it doesn't match. `etimes` (plural,
    seconds directly) is a Linux/procps extension — verified absent from the
    BSD/Darwin ps keyword table, so it cannot be used here; `etime` is the
    keyword present on both. Written defensively (reject anything that
    doesn't parse) rather than assuming byte-for-byte identical output across
    ps implementations."""
    s = s.strip()
    days = 0
    if "-" in s:
        d, _, s = s.partition("-")
        try:
            days = int(d)
        except ValueError:
            return None
    parts = s.split(":")
    try:
        parts = [int(p) for p in parts]
    except ValueError:
        return None
    if len(parts) == 2:
        h, m, sec = 0, parts[0], parts[1]
    elif len(parts) == 3:
        h, m, sec = parts
    else:
        return None
    return days * 86400 + h * 3600 + m * 60 + sec


def _process_start_epoch(pid):
    """Best-effort absolute start time (epoch seconds) for `pid`, derived from
    `ps -o etime=` (elapsed running time, `[[DD-]hh:]mm:ss`) rather than
    `ps -o lstart=` (a locale/OS-dependent date string, fragile to compare
    across machines) or `ps -o etimes=` (elapsed seconds directly — NOT
    portable: confirmed absent from the BSD/Darwin ps keyword table, GNU/
    procps only). `etime` is present on both GNU and BSD ps; no /proc. None
    if ps is unavailable, the pid can't be queried, or the output doesn't
    parse."""
    try:
        out = subprocess.run(["ps", "-o", "etime=", "-p", str(pid)],
                              capture_output=True, text=True, timeout=3).stdout.strip()
        elapsed = _parse_etime(out)
        if elapsed is None:
            return None
    except Exception:
        return None
    return time.time() - elapsed


def watcher_pidfile_path(cwd, pid):
    return os.path.join(cwd, "%s.%d" % (WATCHER_PIDFILE_BASE, pid))


def _pid_alive(pid):
    """True if a process with `pid` exists. EPERM means it exists but belongs
    to another user — still alive, so still owning its record."""
    try:
        os.kill(pid, 0)
    except ProcessLookupError:
        return False
    except PermissionError:
        return True
    except OSError:
        return True
    return True


def _read_watcher_pid(path):
    """The `pid=` value from a watcher liveness record, or None."""
    try:
        with open(path) as f:
            for line in f:
                if line.startswith("pid="):
                    return int(line[4:].strip())
    except (OSError, ValueError):
        return None
    return None


def _sweep_dead_watcher_pidfiles(cwd, keep_pid):
    """Delete liveness records whose watcher is gone. Per-pid records are only
    ever removed by their own watcher's teardown, so one killed with SIGKILL
    (or a temp file from an interrupted write) would otherwise linger forever.
    Harmless if it does — the hook already treats a dead pid as no watcher —
    so this is litter control, and deliberately conservative: an unreadable or
    still-live record is left alone."""
    try:
        names = os.listdir(cwd)
    except OSError:
        return
    for name in names:
        if not name.startswith(WATCHER_PIDFILE_BASE):
            continue
        path = os.path.join(cwd, name)
        pid = _read_watcher_pid(path)
        if pid is None or pid == keep_pid or _pid_alive(pid):
            continue
        try:
            os.remove(path)
        except OSError:
            pass


def write_watcher_pidfile(cwd, pid):
    """Record `pid` (this ccage-auto process) as A live watcher for cwd, with a
    start-time token alongside it so a later reader can detect pid reuse (see
    resume_autoload.sh). Written to a temp file and renamed, so a hook reading
    the directory mid-write never sees a truncated record (which would read as
    "no watcher" and clear state this watcher still depends on). Best-effort: a
    failure here just means the hook falls back to its own conservative default
    instead of blocking anything on a file that was never written."""
    start = _process_start_epoch(pid)
    path = watcher_pidfile_path(cwd, pid)
    # Temp name deliberately shares the WATCHER_PIDFILE_BASE prefix (so the
    # sweep above reclaims it) while NOT matching the hook's `.pid.<pid>` read
    # glob (so a leftover temp is never mistaken for a record).
    tmp = os.path.join(cwd, "%stmp.%d" % (WATCHER_PIDFILE_BASE, pid))
    try:
        with open(tmp, "w") as f:
            f.write("pid=%d\n" % pid)
            if start is not None:
                f.write("start=%d\n" % int(start))
        os.replace(tmp, path)
        _git_exclude(cwd, WATCHER_PIDFILE_GLOB)
    except OSError:
        try:
            os.remove(tmp)
        except OSError:
            pass
        return
    _sweep_dead_watcher_pidfiles(cwd, pid)


def remove_watcher_pidfile(cwd, pid):
    """Remove only THIS watcher's record. A watcher never touches a sibling's:
    that is what keeps a concurrent watcher in the same directory represented
    after this one exits."""
    try:
        os.remove(watcher_pidfile_path(cwd, pid))
    except OSError:
        pass


# The live control file, written by the /checkpoint-threshold skill (or by
# `ccage-auto --set/--pause/--resume/--reset`). A running watcher re-reads it
# every poll, so the soft/hard thresholds and a pause switch can be changed
# mid-session with no restart. Deliberately in cwd (where the session's own Bash
# runs and where the watcher already looks for the done-marker) and NOT
# slot-scoped: it's a coarse per-directory override for this one run. The
# SessionStart hook clears it on a genuinely new session (startup/resume) so a
# stale override never carries over — but it survives ccage-auto's own /clear
# (source=clear), which is the whole point.
AUTOCK_CONF = ".ccage-autock.conf"


def control_path(cwd):
    return os.path.join(cwd, AUTOCK_CONF)


def read_control_file(cwd):
    """Parse the control file into {'soft': float, 'hard': float, 'paused': bool}.

    Only keys actually present are returned; blank/`#`/malformed lines and
    unparseable values are ignored, so a half-written file (the watcher may read
    it mid-write) degrades to 'no override' rather than crashing the thread."""
    out = {}
    try:
        with open(control_path(cwd)) as f:
            raw = f.read()
    except OSError:
        return out
    for line in raw.splitlines():
        line = line.strip()
        if not line or line.startswith("#") or "=" not in line:
            continue
        key, _, val = line.partition("=")
        key = key.strip().lower()
        val = val.strip()
        if key in ("soft", "hard"):
            try:
                out[key] = float(val)
            except ValueError:
                pass
        elif key == "paused":
            out[key] = val.lower() not in ("0", "false", "no", "off", "")
    return out


def _git_exclude(cwd, name):
    """Best-effort: add `name` to this repo's .git/info/exclude (like the
    done-marker and RESUME), so the control file never shows up as untracked.
    A no-op outside a git repo or if anything fails."""
    try:
        gd = subprocess.run(["git", "rev-parse", "--git-dir"], cwd=cwd,
                            capture_output=True, text=True, timeout=5).stdout.strip()
    except Exception:
        return
    if not gd:
        return
    if not os.path.isabs(gd):
        gd = os.path.join(cwd, gd)
    ex = os.path.join(gd, "info", "exclude")
    try:
        os.makedirs(os.path.dirname(ex), exist_ok=True)
        existing = ""
        if os.path.isfile(ex):
            with open(ex) as f:
                existing = f.read()
        if name not in existing.split():
            with open(ex, "a") as f:
                f.write(name + "\n")
    except OSError:
        pass


def write_control_file(cwd, updates):
    """Merge `updates` into the control file and rewrite it. A key whose value is
    None is removed. Returns the resulting dict. Idempotently git-excludes the
    file. Note: this does NOT clamp — callers (`--set`) validate first so the
    user sees any warning; the watcher re-clamps on read as a backstop."""
    cur = read_control_file(cwd)
    for k, v in updates.items():
        if v is None:
            cur.pop(k, None)
        else:
            cur[k] = v
    lines = [
        "# ccage-auto live control file — written by /checkpoint-threshold.",
        "# A running watcher re-reads this each poll; it is cleared at the next",
        "# session start. For a permanent change use --soft/--hard or",
        "# CCAGE_AUTOCK_SOFT/CCAGE_AUTOCK_HARD at launch.",
    ]
    if "soft" in cur:
        lines.append("soft=%g" % float(cur["soft"]))
    if "hard" in cur:
        lines.append("hard=%g" % float(cur["hard"]))
    if "paused" in cur:
        lines.append("paused=%d" % (1 if cur["paused"] else 0))
    with open(control_path(cwd), "w") as f:
        f.write("\n".join(lines) + "\n")
    _git_exclude(cwd, AUTOCK_CONF)
    return cur


# ----------------------------------------------------------------------------
# The watcher (runs in a thread; injects by writing to the pty master fd)
# ----------------------------------------------------------------------------

class Watcher:
    # states
    NORMAL = "normal"
    NUDGED = "nudged"
    COOLDOWN = "cooldown"

    def __init__(self, cfg, master_fd, write_lock, cwd, sdir, logf):
        self.cfg = cfg
        self.fd = master_fd
        self.lock = write_lock
        self.cwd = cwd
        self.sdir = sdir
        self.log = logf
        self.state = self.NORMAL
        self.stop = False
        # Launch-time thresholds, kept so the live control file can be *removed*
        # (or a key dropped) and we revert to exactly what the run started with —
        # not to the built-in defaults.
        self.base_soft = cfg.soft
        self.base_hard = cfg.hard
        # Whether base_hard was explicitly named at launch (--hard /
        # CCAGE_AUTOCK_HARD) vs. derived from base_soft. A live control-file
        # override that touches only soft, with no explicit hard anywhere,
        # should keep re-deriving hard from the new soft — but an explicit
        # launch --hard stays sticky until something explicitly overrides it.
        self.base_hard_explicit = cfg.hard_explicit
        self.paused = False        # set by a `paused=1` control file
        self.conf_mtime = -1.0     # last-seen mtime of the control file
        # A `.ccage-session-done` marker newer than this counts as "this run's
        # work is finished." Anchoring on start time means a stale marker from a
        # previous run (which the SessionStart hook also clears at startup) can
        # never trip an immediate stand-down before any work has happened.
        self.start_time = time.time()
        self.tui_ready = threading.Event()
        self.nudge_at = 0.0
        self.nudge_offset = 0     # transcript byte offset at nudge time
        self.nudge_path = None    # transcript file current at nudge time
        self.renudges = 0
        self.hard_fired = False   # hard-threshold escalation done for this cycle
        self.cooldown_until = 0.0
        self.last_path = None     # transcript path of the last occupancy reading
        self.last_sz = -1         # size of that transcript at the last reading
        self.last_tokens = None   # assistant tokens at the last reading
        self.last_pct = None      # last measured occupancy %, reused between turns
        # Weekly-limit floor. sdir is <config-dir>/projects/<slug>; the state
        # file the statusline tee writes sits at the config root, so climb two
        # levels (same derivation as SubagentWatcher.config_root).
        self.config_root = os.path.dirname(os.path.dirname(sdir))
        self.wf_stage = "none"        # "none" | "warned" | "floored"
        self.wf_stale_logged = False  # log the missing/stale sensor once, not per poll

    def _log(self, msg):
        try:
            self.log.write("%s  %s\n" % (time.strftime("%H:%M:%S"), msg))
            self.log.flush()
        except Exception:
            pass

    def _write(self, data):
        """Write to the pty master, tolerating the child having exited.

        If the session has gone away mid-injection the fd is closed/broken; treat
        that as a stop signal rather than letting the watcher thread die on an
        unhandled OSError."""
        try:
            os.write(self.fd, data)
            return True
        except OSError:
            self.stop = True
            return False

    def _type(self, text, submit=True, settle=KEY_DELAY):
        with self.lock:
            if not self._write(text.encode()):
                return
            if submit:
                time.sleep(settle)
                self._write(b"\r")

    def _interrupt(self):
        # Escape interrupts a running turn (forces the model to yield) and also
        # dismisses any open autocomplete menu when the prompt is idle.
        with self.lock:
            self._write(b"\x1b")
        time.sleep(0.5)

    def _soft_nudge(self, pct):
        if self.cfg.nudge:
            msg = self.cfg.nudge.replace("{pct}", "%.0f" % pct).replace("{sentinel}", self.cfg.sentinel)
        else:
            # Advisory, not an order: the model weighs the cost. It may hold off if
            # checkpointing now would lose in-flight work (a running subagent, a
            # mid-edit) — the hard threshold below is the real deadline.
            msg = (
                "[auto-checkpoint] Context is at %.0f%% of the window — a good moment "
                "to checkpoint soon, but use your judgment; prioritise not losing "
                "work. If a subagent is still running, or you are mid-task where "
                "clearing now would drop in-flight results, finish that first. When "
                "you reach a clean breakpoint (never interrupt an in-progress edit or "
                "a running subagent), invoke the checkpoint skill to update "
                "RESUME.md, then print the single token %s on its own line and stop; "
                "this session is then cleared and resumed from RESUME.md "
                "automatically. If now is a bad moment, hold off — you will be "
                "reminded, and a hard backstop fires before the window fills." % (pct, self.cfg.sentinel)
            )
        self._type(msg)

    def _hard_nudge(self, pct):
        if self.cfg.hard_nudge:
            msg = self.cfg.hard_nudge.replace("{pct}", "%.0f" % pct).replace("{sentinel}", self.cfg.sentinel)
        else:
            # The backstop: past here, auto-compact is near and would lose more
            # than a checkpoint. Still respect a running subagent (wait for it),
            # but do not defer beyond that.
            msg = (
                "[auto-checkpoint] Context is at %.0f%% — the hard backstop. "
                "Auto-compact is close and would lose more than a checkpoint does, "
                "so wrap up at the very next safe point: if a subagent is running, "
                "wait for it to return, then immediately invoke the checkpoint skill "
                "to update RESUME.md, print %s on its own line, and stop. Do not "
                "start new work." % (pct, self.cfg.sentinel)
            )
        self._type(msg)

    def _arm_nudge(self, path, pct, hard=False):
        """Stamp the nudge time + the transcript file/offset, then type the soft
        (advisory) or hard (backstop) nudge. We pin the *file* current at nudge
        time (not just the offset): the model echoes the sentinel into it before
        we /clear rotates to a new file, so scanning that pinned file keeps
        confirmation correct across rotation."""
        self.nudge_at = time.time()
        self.nudge_path = path
        self.nudge_offset = os.path.getsize(path)
        if hard:
            self._hard_nudge(pct)
        else:
            self._soft_nudge(pct)

    def _refresh_control(self):
        """Re-read the live control file (mtime-gated) and apply soft/hard/paused
        over the launch baseline. An absent file or a dropped key reverts to the
        launch value. Clamped with the same rules as the launch flags.

        hard is explicit whenever the control file names it directly; failing
        that, it's explicit only if the LAUNCH hard was (base_hard_explicit) —
        so a live `--set soft=N` with no hard anywhere keeps re-deriving hard
        from the new soft, exactly like a fresh launch would."""
        try:
            mt = os.path.getmtime(control_path(self.cwd))
        except OSError:
            mt = 0.0
        if mt == self.conf_mtime:
            return
        self.conf_mtime = mt
        ov = read_control_file(self.cwd) if mt else {}
        if "hard" in ov:
            hard_in = ov["hard"]
        else:
            hard_in = self.base_hard if self.base_hard_explicit else None
        soft, hard, renudge, _ = clamp_thresholds(ov.get("soft", self.base_soft), hard_in)
        paused = bool(ov.get("paused", False))
        if (soft != self.cfg.soft or hard != self.cfg.hard
                or renudge != self.cfg.renudge or paused != self.paused):
            self._log("control update: soft=%.0f%% hard=%.0f%% renudge=%.0f%% paused=%s"
                      % (soft, hard, renudge, paused))
        self.cfg.soft = soft
        self.cfg.hard = hard
        self.cfg.renudge = renudge
        if paused != self.paused:
            self.paused = paused
            if not paused:
                # Un-pausing: re-arm from a clean slate so occupancy re-triggers.
                self.state = self.NORMAL

    def _weekly_warn_msg(self, remaining):
        return (
            "[weekly-limit floor] Warning: remaining weekly capacity is %.0f%%, "
            "approaching the configured floor of %.0f%%. Reach a clean breakpoint "
            "and checkpoint soon — when the floor is hit, a checkpoint is forced "
            "and this autonomous run stands down (the session will then be safe "
            "to close until the weekly limit resets)."
            % (remaining, self.cfg.weekly_floor)
        )

    def _weekly_floor_msg(self, remaining):
        return (
            "[weekly-limit floor] Remaining weekly capacity is %.0f%% — at the "
            "configured floor (%.0f%%). This autonomous run is standing down. "
            "If a subagent is running, wait for it to return, but start nothing "
            "new; then immediately invoke the checkpoint skill to save state "
            "into RESUME.md, print the single token %s on its own line, and "
            "stop. The session will NOT be cleared or resumed — it is safe to "
            "close until the weekly limit resets."
            % (remaining, self.cfg.weekly_floor, self.cfg.sentinel)
        )

    def _arm_weekly(self, path, remaining):
        """Stamp the shared nudge fields (safe: once FLOORED the occupancy
        machine is frozen out, so there is no competing writer) and type the
        stand-down order. Same file/offset pinning as _arm_nudge, for the same
        sentinel-across-rotation reason."""
        self.nudge_at = time.time()
        self.nudge_path = path
        self.nudge_offset = os.path.getsize(path)
        self._type(self._weekly_floor_msg(remaining))

    def _weekly_resume_note(self, remaining, resets):
        """Append the stand-down record to RESUME.md so the next session (and
        the user) sees WHY the run stopped, not just that it did."""
        p = os.path.join(self.cwd, "RESUME%s.md" % slot_suffix())
        note = (
            "\n> [ccage-auto] Stood down at the weekly-limit floor on %s — "
            "%.0f%% of weekly capacity remaining (floor %.0f%%); seven-day "
            "window resets %s. No further auto-driven turns this run.\n"
            % (time.strftime("%Y-%m-%d %H:%M"), remaining, self.cfg.weekly_floor,
               resets or "at an unknown time")
        )
        try:
            with open(p, "a") as f:
                f.write(note)
        except OSError as e:
            self._log("weekly floor: could not append RESUME note: %r" % e)

    def _weekly_tick(self, path):
        """One weekly-limit floor evaluation. Returns True while the floor
        machine OWNS the session (floored: forcing the checkpoint, then
        standing down) — the caller must then skip the occupancy machine, both
        because a /clear would defeat the stand-down and because the floored
        stage borrows the shared nudge/confirmation fields."""
        cfg = self.cfg
        remaining, resets, age = read_weekly_state(self.config_root)
        if remaining is None or age > WEEKLY_STALE_S:
            # Unknown ≠ safe to act: a dead sensor must neither trigger a
            # stand-down nor cancel one already in progress.
            if not self.wf_stale_logged:
                self._log("weekly floor: sensor %s — treating as unknown, no action"
                          % ("missing/unreadable" if remaining is None
                             else "stale (%.0f min old)" % (age / 60.0)))
                self.wf_stale_logged = True
            return self.wf_stage == "floored"
        self.wf_stale_logged = False
        warn_at = cfg.weekly_floor + WEEKLY_WARN_MARGIN

        if remaining > warn_at:
            # The seven-day window rolled over (or the floor was lowered):
            # whatever stage we were in — including an unconfirmed floored
            # stand-down — is moot. Mirrors the occupancy machine's
            # NUDGED -> pct<soft cancellation.
            if self.wf_stage != "none":
                self._log("weekly floor: %.1f%% remaining is back above the "
                          "warn threshold (%.1f%%) — resetting"
                          % (remaining, warn_at))
                self.wf_stage = "none"
            return False

        if self.wf_stage == "floored":
            if self._confirmed():
                self._log("weekly floor: checkpoint confirmed — standing down "
                          "(%.1f%% remaining, floor %.0f%%)"
                          % (remaining, cfg.weekly_floor))
                self._weekly_resume_note(remaining, resets)
                self.stop = True
            elif (time.time() - self.nudge_at) > cfg.nudge_timeout:
                self._log("weekly floor: no checkpoint after %.0fs — re-nudging"
                          % cfg.nudge_timeout)
                if cfg.hard_interrupt:
                    self._interrupt()
                self._arm_weekly(path, remaining)
            return True

        if remaining <= cfg.weekly_floor:
            self._log("weekly floor REACHED: %.1f%% remaining <= floor %.0f%% "
                      "— forcing checkpoint, then standing down"
                      % (remaining, cfg.weekly_floor))
            if cfg.hard_interrupt:
                self._interrupt()
            self._arm_weekly(path, remaining)
            self.wf_stage = "floored"
            return True

        if self.wf_stage == "none":
            self._log("weekly floor WARN: %.1f%% remaining <= %.1f%% "
                      "(floor %.0f%% + %g%% margin)"
                      % (remaining, warn_at, cfg.weekly_floor, WEEKLY_WARN_MARGIN))
            self._type(self._weekly_warn_msg(remaining))
            self.wf_stage = "warned"
        return False

    def _do_clear(self):
        self._interrupt()                # dismiss any menu / ensure clean line
        self._type("/clear", settle=KEY_DELAY)
        time.sleep(CLEAR_SETTLE)         # let SessionStart:clear reload RESUME
        self._type("Resume the task from RESUME.md — continue from the ### Next "
                   "section. Do not re-do completed work.")

    def _new_text_since_nudge(self):
        """Assistant text appended to the pinned nudge-time transcript after the
        nudge, for sentinel detection."""
        if not self.nudge_path:
            return ""
        try:
            with open(self.nudge_path, "rb") as f:
                f.seek(self.nudge_offset)
                data = f.read()
        except OSError:
            return ""
        out = []
        for line in data.split(b"\n"):
            if b'"assistant"' not in line:
                continue
            try:
                obj = json.loads(line)
            except ValueError:
                continue
            if obj.get("type") != "assistant":
                continue
            for blk in (obj.get("message") or {}).get("content") or []:
                if isinstance(blk, dict) and blk.get("type") == "text":
                    out.append(blk.get("text", ""))
        return "\n".join(out)

    def _confirmed(self):
        seen = self.cfg.sentinel in self._new_text_since_nudge()
        resume_fresh = resume_mtime(self.cwd) > self.nudge_at
        # Sentinel is primary; RESUME freshness corroborates.
        if seen and resume_fresh:
            return True
        if seen and (time.time() - self.nudge_at) > 20:
            return True
        return False

    def run(self):
        cfg = self.cfg
        self._log("watcher start: soft=%.0f%% hard=%.0f%% poll=%.0fs%s"
                  % (cfg.soft, cfg.hard, cfg.poll,
                     " weekly-floor=%.0f%%" % cfg.weekly_floor
                     if cfg.weekly_floor > 0 else ""))
        # Autonomous kickoff: submit the initial task once the TUI is ready (after
        # any bypass-permissions accept). Without this an unattended session idles
        # at an empty prompt and never produces work to manage.
        if cfg.init_prompt and not self.stop:
            deadline = time.time() + cfg.init_delay
            while not self.stop:
                remaining = deadline - time.time()
                if remaining <= 0:
                    self._log("ready-marker not seen after %.0fs — typing init prompt anyway"
                              % cfg.init_delay)
                    break
                if self.tui_ready.wait(timeout=min(remaining, 0.5)):
                    time.sleep(1.0)          # settle: let the frame finish painting
                    if self.tui_ready.is_set():   # not invalidated by bypass-accept
                        self._log("TUI ready after %.1fs — sending init prompt"
                                  % (cfg.init_delay - remaining + 1.0))
                        break
            if not self.stop:
                self._type(cfg.init_prompt)
        while not self.stop:
            time.sleep(cfg.poll)
            # Stand down the moment the session is marked done (/checkpoint
            # --final). ccage-auto is a persistent process that owns the /clear
            # cycles, so — unlike /keepwarm — it reads the marker with no
            # /clear-survival caveat: this is the load-bearing consumer. Standing
            # down stops the nudge/clear state machine but leaves the claude
            # session itself running for the user.
            if session_done_mtime(self.cwd) > self.start_time:
                self._log("session marked done (%s) — standing down; "
                          "no more nudges/clears" % SESSION_DONE_MARKER)
                self.stop = True
                break
            # Live thresholds / pause (mid-session /checkpoint-threshold). Read
            # every poll but re-parsed only when the file's mtime changes.
            self._refresh_control()
            if self.paused:
                # Suspended: no nudges/clears. We keep polling so a `resume`
                # (and the done-marker) are still seen promptly.
                continue
            path = active_jsonl(self.sdir, self.start_time)
            if not path:
                continue

            try:
                sz = os.path.getsize(path)
            except OSError:
                continue

            # Re-measure occupancy only when the active transcript changed or grew,
            # and only treat a changed token count as a fresh reading — growth from
            # user typing or a logged /clear keeps the last pct. Skipping the
            # *re-parse* must never skip the state machine below: a stalled or
            # idle-over-threshold session still has to be nudged, re-nudged, and
            # hard-interrupted on the timed cadence even while nothing new is logged.
            if path != self.last_path:
                self.last_path = path
                self.last_sz = -1
                self.last_tokens = None
                self.last_pct = None
            if sz != self.last_sz:
                self.last_sz = sz
                tokens, model = latest_usage(path)
                if tokens is not None and tokens != self.last_tokens:
                    self.last_tokens = tokens
                    self.last_pct = 100.0 * tokens / cfg.window_for(model)

            # Weekly-limit floor: evaluated before the occupancy machine, and
            # while it owns the session (floored) the occupancy machine is
            # skipped entirely — a /clear would defeat the stand-down, and the
            # floored stage borrows the shared nudge/confirmation fields.
            if cfg.weekly_floor > 0 and self._weekly_tick(path):
                continue

            if self.last_pct is None or self.last_tokens is None:
                continue
            tokens = self.last_tokens
            pct = self.last_pct

            if self.state == self.COOLDOWN:
                if time.time() >= self.cooldown_until and pct < cfg.soft:
                    self._log("reset complete (%.1f%%); back to NORMAL" % pct)
                    self.state = self.NORMAL
                continue

            if self.state == self.NORMAL:
                if pct >= cfg.soft:
                    self._log("soft threshold hit at %.1f%% (%d tok) — nudging" % (pct, tokens))
                    self.renudges = 0
                    self.hard_fired = False
                    self._arm_nudge(path, pct)
                    self.state = self.NUDGED
                continue

            if self.state == self.NUDGED:
                if self._confirmed():
                    # FIRST, ahead of the below-soft cancellation: a confirmed
                    # checkpoint is work the model has already done, and the
                    # only thing that finishes it is the /clear. Observed:
                    # nudge at 35.1%, model checkpointed, then a live
                    # `--set soft=45` raised the threshold past the current
                    # 38.2% — the cancellation ran first, discarded the
                    # confirmation, and the session sat parked forever with
                    # its checkpoint written and no clear (the model had
                    # printed the sentinel and stopped, so nothing else was
                    # coming). Safe to prefer: _confirmed() needs the sentinel
                    # in text logged SINCE the nudge, so it cannot fire on a
                    # stale arm or a manual /clear.
                    self._log("checkpoint confirmed at %.1f%% — clearing" % pct)
                    self._do_clear()
                    self.cooldown_until = time.time() + cfg.cooldown
                    self.state = self.COOLDOWN
                elif pct < cfg.soft:
                    # Occupancy fell below soft (manual /clear, a stale arm, a
                    # threshold raise) with nothing checkpointed: the nudge is
                    # moot. Never re-nudge or escalate below the live
                    # threshold — stand down instead.
                    self._log("occupancy %.1f%% < soft %.0f%% — cancelling "
                              "nudge cycle; back to NORMAL" % (pct, cfg.soft))
                    self.state = self.NORMAL
                elif pct >= cfg.hard and not self.hard_fired:
                    # Fire the forceful escalation ONCE per nudge cycle. Re-firing
                    # every poll would re-interrupt the model mid-checkpoint and
                    # keep resetting nudge_at, so the timed fallbacks in
                    # _confirmed() could never accumulate. After this, fall through
                    # to the nudge_timeout cadence below.
                    self._log("HARD threshold at %.1f%% — forcing checkpoint" % pct)
                    if cfg.hard_interrupt:
                        self._interrupt()
                    self.hard_fired = True
                    self._arm_nudge(path, pct, hard=True)
                elif self.renudges < MAX_RENUDGE and (
                        pct >= cfg.renudge or (time.time() - self.nudge_at) > cfg.nudge_timeout):
                    # Occupancy-anchored re-nudge (hard - RENUDGE_MARGIN), with the
                    # timer kept as a fallback for a session that stalls below that
                    # line — whichever fires first. Same soft-style message either
                    # way; only the trigger moved.
                    if pct >= cfg.renudge:
                        self._log("occupancy %.1f%% reached the re-nudge line (%.0f%%) "
                                  "— re-nudging" % (pct, cfg.renudge))
                    else:
                        self._log("no checkpoint after %.0fs — re-nudging" % cfg.nudge_timeout)
                    self.renudges += 1
                    self._arm_nudge(path, pct)
                elif (time.time() - self.nudge_at) > cfg.nudge_timeout:
                    self._log("re-nudge exhausted — interrupting + nudging")
                    if cfg.hard_interrupt:
                        self._interrupt()
                    self._arm_nudge(path, pct, hard=True)
                    self.renudges = 0


# ----------------------------------------------------------------------------
# Circuit breaker — subagent watchdog thread (observe mode, Phase 1)
# ----------------------------------------------------------------------------

class SubagentWatcher:
    """A second daemon thread beside the context Watcher. Each poll it evaluates
    every subagent transcript for the stuck-subagent circuit breaker (observe
    mode). All decision logic is the unit-tested lib.subagent_watch.run_tick;
    this owns only config/state/paths and the poll loop, so a bug here can lose
    a breaker tick but never corrupt the session it guards (every tick is
    exception-guarded and best-effort). Instantiated only when the CB library
    loaded (_ccb_watch is not None)."""

    def __init__(self, poll, cwd, sdir, logf, master_fd=None, write_lock=None,
                 ready_event=None, pid=None):
        self.poll = poll
        self.cwd = cwd
        self.sdir = sdir
        self.log = logf
        # Injection wiring (Task 12). master_fd/write_lock are the same pty
        # master and lock the context Watcher and the bypass auto-accepter use,
        # so a nudge never interleaves bytes with another writer. All three
        # default to None: in observe mode (or any construction that doesn't
        # wire the pty) inject_message is a logged no-op, so a nudge degrades to
        # log-only rather than raising.
        self.master_fd = master_fd
        self.write_lock = write_lock
        self.ready_event = ready_event
        # Tier C (Task 15): the pty child pid from run_proxy's pty.fork(), so a
        # session-kill reuses the existing handle instead of inventing a second
        # mechanism. None => kill_session is a logged no-op.
        self.pid = pid
        self._injected_this_tick = False   # rate-limit: one injection per poll
        self.stop = False
        self.start_time = time.time()
        self.cfg = _ccb_types.CCBConfig.from_env()
        self.state_path = os.path.join(sdir, ".ccb-state.json")
        self.state = _ccb_watch.load_state(Path(self.state_path))
        # sdir is <config-dir>/projects/<slug>; the tasks/ dir sits at the config
        # root, so climb two levels for open_task_count's search root.
        self.config_root = os.path.dirname(os.path.dirname(sdir))
        self.resume_path = os.path.join(cwd, "RESUME%s.md" % slot_suffix())
        # Same durable ledger bin/ccb-report reads (Task 10b / Task 18).
        self.ledger_path = os.path.expanduser(
            os.environ.get("CCB_LEDGER", "~/.local/share/ccage/ccb/events.jsonl"))
        self.flags = {}

    def _log(self, msg):
        try:
            self.log.write("%s  [ccb] %s\n" % (time.strftime("%H:%M:%S"), msg))
            self.log.flush()
        except Exception:
            pass

    def inject_message(self, text):
        """Write a Tier-A nudge to the child's pty exactly as a human types it:
        the text, a settle pause, then `\\r` to submit (spike S1's confirmed
        byte shape — reaches a running model at the next tool boundary, queues
        mid-tool). Newlines are collapsed to spaces first: S1 verified a
        single-line submit; a multi-line paste's submit behaviour is unverified,
        so we never rely on it. Serialized behind the shared write_lock and
        rate-limited to one injection per poll tick. Returns True on a real
        write; a logged no-op (False) when no pty is wired, the TUI isn't ready
        yet (bypass screen still up — Task 12 Step 2 guard, reusing the context
        watcher's ready_event), the tick already injected, or the child is gone."""
        first = text.splitlines()[0] if text else ""
        if self._injected_this_tick:
            self._log("inject rate-limited this tick: %s" % first)
            return False
        if self.master_fd is None or self.write_lock is None:
            self._log("inject skipped (no pty): %s" % first)
            return False
        if self.ready_event is not None and not self.ready_event.is_set():
            self._log("inject skipped (TUI not ready): %s" % first)
            return False
        line = " ".join(text.split())      # collapse all whitespace/newlines
        with self.write_lock:
            try:
                os.write(self.master_fd, line.encode())
                time.sleep(KEY_DELAY)
                os.write(self.master_fd, b"\r")
            except OSError as e:
                self._log("inject failed (child gone?): %r" % e)
                return False
        self._injected_this_tick = True
        self._log("injected nudge: %s" % first)
        return True

    def kill_session(self, teammate_id):
        """Tier C (Task 15): terminate the pty child — the whole claude session.
        Reuses the handle run_proxy already owns (self.pid from pty.fork): a
        SIGTERM lets the read loop hit EOF and run the existing teardown
        (waitpid), so there is no second kill mechanism. Best-effort — a missing
        pid or an already-dead child is a logged no-op. Only ever reached when
        run_tick's kill_permitted gate passed (CCB_MAX_TIER=kill + unresponsive
        orchestrator)."""
        if self.pid is None:
            self._log("kill skipped (no pid): escalated on %s" % teammate_id)
            return False
        self._log("TIER-C: SIGTERM to session pid %d (escalated on teammate %s)"
                  % (self.pid, teammate_id))
        try:
            os.kill(self.pid, signal.SIGTERM)
        except OSError as e:
            self._log("kill failed (child already gone?): %r" % e)
            return False
        self.stop = True    # stand this watcher down; run_proxy tears the child down
        return True

    def run(self):
        self._log("ccb watcher start: max_tier=%s soft=%dmin stale=%dmin hard=%dmin poll=%.0fs"
                  % (self.cfg.max_tier.value, self.cfg.t_soft_min, self.cfg.t_stale_min,
                     self.cfg.t_hard_min, self.poll))
        while not self.stop:
            time.sleep(self.poll)
            # Stand down with the session when its work is marked done, matching
            # the context watcher (line ~845). ccage-auto owns the /clear cycle,
            # so the done-marker is read with no /clear-survival caveat.
            if session_done_mtime(self.cwd) > self.start_time:
                self._log("session marked done — ccb standing down")
                self.stop = True
                break
            try:
                self._tick()
            except Exception as e:
                # The breaker must never take down the session it guards.
                self._log("tick error (ignored): %r" % e)

    def _tick(self):
        parent = active_jsonl(self.sdir, self.start_time)
        # The transcript basename (sans .jsonl) is the session id tokenol and the
        # task-dir lookups key on; empty until the session writes its first file.
        session_id = os.path.splitext(os.path.basename(parent))[0] if parent else ""
        # The orchestrator's model id (from the latest assistant turn) is captured
        # in every ledger row — reuse the context watcher's transcript reader so
        # there is one source of truth for "what model is the root running on".
        orchestrator_model = latest_usage(parent)[1] if parent else None
        self._injected_this_tick = False   # reset the one-per-tick rate limit
        self.state = _ccb_watch.run_tick(
            session_dir=Path(self.sdir),
            config_root=Path(self.config_root),
            session_id=session_id,
            cwd=self.cwd,
            cfg=self.cfg,
            state=self.state,
            now=time.time(),
            parent_transcript=Path(parent) if parent else None,
            resume_path=Path(self.resume_path),
            ledger_path=Path(self.ledger_path),
            state_path=Path(self.state_path),
            orchestrator_model=orchestrator_model,
            log=self._log,
            inject=self.inject_message,
            kill_session=self.kill_session,
            flags=self.flags,
        )


# ----------------------------------------------------------------------------
# pty proxy
# ----------------------------------------------------------------------------

def set_winsize(fd):
    try:
        sz = fcntl.ioctl(0, termios.TIOCGWINSZ, b"\x00" * 8)
        fcntl.ioctl(fd, termios.TIOCSWINSZ, sz)
    except OSError:
        pass


def run_proxy(cfg, cwd, sdir, logpath):
    shell = os.environ.get("SHELL", "/bin/bash")
    # CCAGE_AUTOCK_EXEC overrides the command launched inside the pty (default the
    # cage's `claude` shell function). For custom launchers and for testing.
    launch = launch_command(cfg)
    child_argv = [shell, "-ic", launch, shell] + cfg.claude_args

    pid, master_fd = pty.fork()
    if pid == 0:  # child: becomes the cage's claude session
        os.execvp(shell, child_argv)
        os._exit(127)

    set_winsize(master_fd)

    # raw mode on our stdin so keystrokes pass straight through to the TUI
    try:
        old_attr = termios.tcgetattr(0)
        tty.setraw(0)
        raw = True
    except termios.error:
        old_attr = None
        raw = False

    write_lock = threading.Lock()
    logf = open(logpath, "a", buffering=1)
    watcher = Watcher(cfg, master_fd, write_lock, cwd, sdir, logf)
    if cfg.enabled:
        t = threading.Thread(target=watcher.run, daemon=True)
        t.start()
        # This process (not the pty child) is now the live watcher for cwd —
        # record it so resume_autoload.sh can tell a sibling session's own
        # startup apart from "nothing is watching this directory anymore".
        write_watcher_pidfile(cwd, os.getpid())

    # Circuit breaker: a second daemon thread evaluating subagent transcripts.
    # Alerts always; injects a Tier-A nudge only when CCB_MAX_TIER>=nudge on a
    # teams session (the default rollout is observe = alert-only). Shares the
    # context watcher's poll cadence. Optional and best-effort — an absent lib/
    # or a tick error never affects the session.
    ccb_watcher = None
    if cfg.enabled and _ccb_watch is not None and _ccb_types is not None:
        # Share the pty master + write_lock so a Tier-A nudge serializes against
        # the context watcher and the bypass auto-accepter; gate injection on
        # the same tui_ready event the accept path drives (Task 12 Step 2).
        #
        # CCBConfig already fails safe (defaults to observe, and from_env falls
        # back to observe on any absent/garbage/mis-cased CCB_MAX_TIER). This
        # setdefault is belt-and-suspenders and also EXPORTS the tier into the
        # environment so the child session and any subprocess observe the same
        # value; an operator opts up by setting CCB_MAX_TIER before launch.
        os.environ.setdefault("CCB_MAX_TIER", "observe")
        ccb_watcher = SubagentWatcher(cfg.poll, cwd, sdir, logf,
                                      master_fd=master_fd, write_lock=write_lock,
                                      ready_event=watcher.tui_ready, pid=pid)
        threading.Thread(target=ccb_watcher.run, daemon=True).start()

    signal.signal(signal.SIGWINCH, lambda *_: set_winsize(master_fd))

    # A --dangerously-skip-permissions launch in a not-yet-accepted cage opens on
    # a "Bypass Permissions mode" screen defaulting to "No, exit" — an unattended
    # session would hang there. Since the user opted into DSP, auto-accept it
    # (Down -> "Yes, I accept" -> Enter). Opt out with CCAGE_AUTOCK_NO_BYPASS_ACCEPT.
    ANSI = re.compile(rb'\x1b\[[0-9;?]*[a-zA-Z]|\x1b[()][AB0]|\x1b\][^\x07]*\x07|[\x00-\x08\x0e-\x1f]')
    out_buf = b""
    bypass_done = bool(os.environ.get("CCAGE_AUTOCK_NO_BYPASS_ACCEPT"))
    started = time.time()

    stdin_ok = True
    try:
        while True:
            watch = [master_fd] + ([0] if stdin_ok else [])
            try:
                rfds, _, _ = select.select(watch, [], [])
            except select.error as e:
                if e.args[0] == errno.EINTR:
                    continue
                raise
            if master_fd in rfds:
                try:
                    data = os.read(master_fd, 65536)
                except OSError:
                    break
                if not data:
                    break
                os.write(1, data)
                # Scan only while something still needs detecting: the bypass
                # screen (60s window) or TUI readiness (until found or the
                # kickoff ceiling + slack lapses) — never for the whole session.
                elapsed = time.time() - started
                scan_window = elapsed < 60
                ready_window = elapsed < max(60.0, cfg.init_delay + 5.0)
                if (not watcher.tui_ready.is_set() and ready_window) or (not bypass_done and scan_window):
                    out_buf = ANSI.sub(b"", out_buf + data)[-4096:]
                    # Match the screen's distinctive title AND its accept-option
                    # label, not the bare words "Bypass"/"accept" — those occur in
                    # ordinary repo content (changelogs, licences) and a loose
                    # match could fire a spurious Down+Enter into the live TUI.
                    if not bypass_done and scan_window and \
                       b"Bypass Permissions" in out_buf and b"Yes, I accept" in out_buf:
                        with write_lock:
                            os.write(master_fd, b"\x1b[B")   # down -> "Yes, I accept"
                            time.sleep(0.3)
                            os.write(master_fd, b"\r")        # confirm
                        bypass_done = True
                        # The bypass menu renders ❯ as its selection caret — any
                        # readiness inferred from that screen is false. Reset;
                        # the real TUI frame after acceptance re-sets it.
                        out_buf = b""
                        watcher.tui_ready.clear()
                        logf.write("%s  auto-accepted bypass-permissions prompt\n"
                                   % time.strftime("%H:%M:%S"))
                        logf.flush()
                    elif not watcher.tui_ready.is_set() and cfg.ready_marker in out_buf:
                        watcher.tui_ready.set()
                        logf.write("%s  TUI ready-marker seen (%.1fs after launch)\n"
                                   % (time.strftime("%H:%M:%S"), time.time() - started))
                        logf.flush()
            if stdin_ok and 0 in rfds:
                try:
                    data = os.read(0, 65536)
                except OSError:
                    data = b""
                if not data:
                    # stdin hit EOF (non-tty / closed): stop polling it so we don't
                    # busy-spin; the child runs on under watcher control.
                    stdin_ok = False
                else:
                    with write_lock:
                        os.write(master_fd, data)
    finally:
        watcher.stop = True
        if ccb_watcher is not None:
            ccb_watcher.stop = True
        if raw and old_attr is not None:
            termios.tcsetattr(0, termios.TCSADRAIN, old_attr)
        if cfg.enabled:
            remove_watcher_pidfile(cwd, os.getpid())
        try:
            logf.close()
        except Exception:
            pass

    _, status = os.waitpid(pid, 0)
    return os.waitstatus_to_exitcode(status)


# ----------------------------------------------------------------------------
# main
# ----------------------------------------------------------------------------

# The four control-plane subcommands /checkpoint-threshold (and a human) use
# to talk to an already-running watcher.
CONTROL_ACTIONS = ("--set", "--pause", "--resume", "--reset")


def _find_control_action(argv):
    """Index of the first control-plane token in argv, scanning only up to a
    literal `--` — everything after that is unambiguously claude's, even if it
    happens to spell one of these tokens. None if absent.

    Not just argv[0]: `ccage-auto-yolo` (a user alias) expands to `ccage-auto
    --dangerously-skip-permissions --set soft=40` — the control token isn't
    first, but the intent is unambiguous (nothing else in this argv, or in
    claude's own flag set, spells --set/--pause/--resume/--reset), so it must
    still be recognised and dispatched to control_command rather than silently
    forwarded into claude's argv."""
    for idx, a in enumerate(argv):
        if a == "--":
            return None
        if a in CONTROL_ACTIONS:
            return idx
    return None


def control_command(argv):
    """Handle the control-plane subcommands (--set/--pause/--resume/--reset) that
    the /checkpoint-threshold skill uses to talk to a running watcher: write the
    live control file for cwd and exit. Separate from launch so it never spawns a
    session. Returns a process exit code."""
    cwd = os.getcwd()
    action = argv[0]

    if action == "--reset":
        try:
            os.remove(control_path(cwd))
            print("ccage-auto: control file cleared — reverting to launch thresholds")
        except OSError:
            print("ccage-auto: no control file to reset (already at launch thresholds)")
        return 0

    if action == "--pause":
        write_control_file(cwd, {"paused": True})
        print("ccage-auto: auto-checkpoint PAUSED (say resume to re-enable)")
        return 0

    if action == "--resume":
        write_control_file(cwd, {"paused": False})
        print("ccage-auto: auto-checkpoint resumed")
        return 0

    # --set: one or more key=value tokens (space- or comma-separated).
    updates = {}
    for tok in argv[1:]:
        for pair in tok.split(","):
            pair = pair.strip()
            if not pair:
                continue
            if "=" not in pair:
                sys.stderr.write("[ccage-auto] ignored '%s' (want key=value)\n" % pair)
                continue
            k, _, v = pair.partition("=")
            k = k.strip().lower()
            v = v.strip()
            if k not in ("soft", "hard", "paused"):
                sys.stderr.write("[ccage-auto] ignored unknown key '%s'\n" % k)
                continue
            if k == "paused":
                updates[k] = v.lower() not in ("0", "false", "no", "off", "")
                continue
            try:
                updates[k] = float(v)
            except ValueError:
                sys.stderr.write("[ccage-auto] ignored %s=%s (not a number)\n" % (k, v))
    if not updates:
        sys.stderr.write("[ccage-auto] --set: nothing to set (usage: --set soft=50 [hard=65])\n")
        return 2
    # Validate against the *merged* view (existing control-file overrides plus
    # this call's updates) so a lone `soft` is derived/checked against the
    # right `hard` too, and the user sees any clamp/derivation warning now.
    # merged["hard"] absent means "not named anywhere" -> clamp_thresholds
    # derives it from merged's soft (min(soft + HARD_MARGIN, 100)); this has no
    # visibility into a launch-time --hard that was never written to the
    # control file, matching --set's existing scope (it only ever reasons
    # about the control file's own contents, never the running process).
    merged = dict(read_control_file(cwd))
    merged.update(updates)
    if "soft" in merged or "hard" in merged:
        s, h, _, warns = clamp_thresholds(merged.get("soft"), merged.get("hard"))
        for w in warns:
            sys.stderr.write("[ccage-auto] %s\n" % w)
        if "soft" in updates:
            updates["soft"] = s
        if "hard" in updates:
            updates["hard"] = h
    result = write_control_file(cwd, updates)
    parts = []
    if "soft" in result:
        parts.append("soft=%g%%" % result["soft"])
    if "hard" in result:
        parts.append("hard=%g%%" % result["hard"])
    if result.get("paused"):
        parts.append("PAUSED")
    print("ccage-auto: control file updated — %s" % (", ".join(parts) or "(empty)"))
    print("            takes effect within one poll if a watcher is running here.")
    return 0


def print_status(cfg, cwd, config_dir, sdir):
    path = active_jsonl(sdir)
    print("ccage-auto status")
    print("  cwd          :", cwd)
    print("  config dir   :", config_dir)
    print("  session dir  :", sdir, "(exists)" if os.path.isdir(sdir) else "(missing)")
    print("  enabled      :", cfg.enabled)
    print("  launch       :", launch_command(cfg))
    print("  ready marker :", "%s (ceiling %.0fs)" % (cfg.ready_marker.decode("utf-8"), cfg.init_delay))
    print("  soft / hard  : %.0f%% / %.0f%% (launch)" % (cfg.soft, cfg.hard))
    print("  re-nudge     : %.0f%% (occupancy-anchored at hard − %g%%; "
          "%.0fs timeout is the fallback)" % (cfg.renudge, RENUDGE_MARGIN, cfg.nudge_timeout))
    ov = read_control_file(cwd)
    if ov:
        hard_in = ov["hard"] if "hard" in ov else (cfg.hard if cfg.hard_explicit else None)
        eff_soft, eff_hard, eff_renudge, _ = clamp_thresholds(ov.get("soft", cfg.soft), hard_in)
        parts = []
        if "soft" in ov:
            parts.append("soft=%g%%" % ov["soft"])
        if "hard" in ov:
            parts.append("hard=%g%%" % ov["hard"])
        if "paused" in ov:
            parts.append("paused=%s" % ov["paused"])
        print("  control file :", control_path(cwd))
        print("  overrides    :", ", ".join(parts))
        print("  effective    : %.0f%% / %.0f%% (re-nudge %.0f%%)%s"
              % (eff_soft, eff_hard, eff_renudge, "  (PAUSED)" if ov.get("paused") else ""))
    else:
        print("  control file : none (using launch thresholds)")
    if cfg.weekly_floor > 0:
        remaining, resets, age = read_weekly_state(config_dir)
        if remaining is None:
            sensor = "no sensor state (statusline tee not seeded, or no render yet)"
        else:
            sensor = "%.1f%% remaining, sensor %.0f min old%s%s" % (
                remaining, age / 60.0,
                " (STALE)" if age > WEEKLY_STALE_S else "",
                ", resets %s" % resets if resets else "")
        print("  weekly floor : %.0f%% remaining (armed) — %s" % (cfg.weekly_floor, sensor))
    else:
        print("  weekly floor : off")
    if not path:
        print("  transcript   : none found")
        return
    tokens, model = latest_usage(path)
    window = cfg.window_for(model)
    print("  transcript   :", os.path.basename(path))
    print("  model        :", model)
    print("  window       :", window)
    if tokens is None:
        print("  occupancy    : no assistant turn with usage yet")
    else:
        print("  occupancy    : %d tok = %.1f%% of window" % (tokens, 100.0 * tokens / window))


def main():
    argv = sys.argv[1:]
    # Control-plane subcommands (used by /checkpoint-threshold, and by a human
    # directly): mutate the live control file for cwd and exit without
    # launching a session. Found anywhere in argv, not just argv[0] — a user
    # alias like `ccage-auto-yolo` can prepend other flags
    # (`--dangerously-skip-permissions --set soft=40`), and the control token
    # must still win rather than being silently forwarded into claude's argv
    # by Config._parse's "first unrecognised token -> the rest is claude's"
    # fallback. Whatever preceded it (launch-only flags with nothing to do
    # once we're not launching) is simply not relevant here and is dropped.
    idx = _find_control_action(argv)
    if idx is not None:
        return control_command(argv[idx:])

    cfg = Config(argv)
    for w in cfg.validate():
        sys.stderr.write("[ccage-auto] %s\n" % w)
    cwd = os.getcwd()
    config_dir = resolve_config_dir(cwd)
    sdir = session_dir(config_dir, cwd)

    if cfg.status_only:
        print_status(cfg, cwd, config_dir, sdir)
        return 0

    if not cfg.enabled:
        # Transparent pass-through: behave exactly like launching `claude`.
        sys.stderr.write("[ccage-auto] disabled — launching normally\n")
        shell = os.environ.get("SHELL", "/bin/bash")
        launch = os.environ.get("CCAGE_AUTOCK_EXEC") or 'claude "$@"'
        os.execvp(shell, [shell, "-ic", launch, shell] + cfg.claude_args)
        return 127

    # Mark the launched session (and its hooks) as autonomous, and register the
    # AskUserQuestion guard for this run only. The disabled pass-through above
    # is untouched: it behaves exactly like launching `claude`.
    os.environ["CCAGE_AUTONOMOUS"] = "1"
    # This process's own pid, inherited into the launched session's environment
    # so resume_autoload.sh can recognise "the watcher named in the pidfile IS
    # my own launcher" with a plain string compare — zero subprocess calls —
    # instead of walking process ancestry. A deliberate restart under a fresh
    # ccage-auto still needs to clear stale marker files from a PREVIOUS run in
    # this directory; this is what tells the hook apart from "some other,
    # still-running session's watcher".
    os.environ["CCAGE_AUTOCK_WATCHER_PID"] = str(os.getpid())
    # A --weekly-floor flag must reach the child shell as the env var: the
    # ccage wrapper's _ccage_seed_statusline_tee keys on it to seed the sensor
    # tee, and the /checkpoint-threshold status path may read it back.
    if cfg.weekly_floor > 0:
        os.environ["CCAGE_AUTOCK_WEEKLY_FLOOR"] = "%g" % cfg.weekly_floor
    if not _truthy(os.environ.get("CCAGE_AUTOCK_NO_ASK_GUARD"), False):
        guard_settings = write_guard_settings(sdir)
        if guard_settings:
            cfg.claude_args = cfg.claude_args + ["--settings", guard_settings]
        else:
            sys.stderr.write(
                "[ccage-auto] autonomous_ask_guard.sh not found — "
                "AskUserQuestion guard off for this run\n")

    logpath = os.path.join(config_dir, "ccage-autock.log") \
        if os.path.isdir(config_dir) else os.path.join(cwd, ".ccage-autock.log")
    sys.stderr.write(
        "[ccage-auto] auto-checkpoint on — soft %.0f%% / hard %.0f%%, log: %s\n"
        % (cfg.soft, cfg.hard, logpath)
    )
    return run_proxy(cfg, cwd, sdir, logpath)


if __name__ == "__main__":
    try:
        sys.exit(main())
    except KeyboardInterrupt:
        sys.exit(130)
