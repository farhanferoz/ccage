#!/usr/bin/env python3
# ccage-auto — autonomous context manager for a single long-lived Claude session.
#
# Launches a Claude Code session through ccage's normal `claude` shell wrapper,
# but interposes a pseudo-terminal so an in-process watcher can (a) measure the
# session's real context occupancy by reading its transcript JSONL and (b) drive
# the checkpoint -> clear -> resume loop with no human present.
#
# The split of labour:
#   - MEASURE  the watcher reads exact per-turn token usage from the transcript
#              (input + cache_read + cache_creation of the latest assistant turn);
#              no LLM, no estimation, no API calls.
#   - DECIDE   a tiny state machine compares occupancy to a soft and a hard
#              threshold.
#   - DRIVE    at the soft threshold it types a plain-text nudge so the model
#              itself runs the checkpoint skill at a clean breakpoint; once the
#              checkpoint is confirmed on disk it types `/clear` (the one thing
#              the model cannot do for itself) and then a short resume nudge.
#
# Injection is just writing bytes to the pty master fd — identical to a human
# typing — so it costs nothing and needs no tmux. The only model work triggered
# is the checkpoint + resume the user wanted anyway, which is far cheaper than
# letting the window grow to auto-compact.
#
# Enabled by default. Disable per-launch with `--no-autock` or CCAGE_AUTOCK=0;
# when disabled this is a transparent pass-through to the normal `claude`.
#
# Usage:
#   ccage-auto [auto-flags] [-- ] [claude args...]
#   ccage-auto --status            # print resolved paths + current occupancy, exit
#
# Control-plane subcommands (mutate the live control file for cwd, then exit — the
# /checkpoint-threshold skill uses these to retune a *running* watcher):
#   ccage-auto --set soft=50 [hard=65]   # change thresholds mid-session
#   ccage-auto --pause / --resume        # suspend / re-enable auto-checkpointing
#   ccage-auto --reset                   # drop overrides, revert to launch values
#
# Auto-flags (consumed from the front; everything else is passed to claude):
#   --autock / --no-autock         force the watcher on/off (default: on)
#   --soft N                       soft threshold, percent       (default: 35)
#   --hard N                       hard threshold, percent       (default: 55)
#   --window N                     force context window, tokens  (default: per-model)
#   --window-map 'sub=N,sub=N'     per-model windows by id substring
#   --poll N                       poll interval, seconds        (default: 12)
#   --status                       diagnostics only, do not launch
#
# Env equivalents (flags win): CCAGE_AUTOCK, CCAGE_AUTOCK_SOFT, CCAGE_AUTOCK_HARD,
#   CCAGE_AUTOCK_WINDOW, CCAGE_AUTOCK_WINDOWS, CCAGE_AUTOCK_POLL,
#   CCAGE_AUTOCK_SENTINEL, CCAGE_AUTOCK_HARD_INTERRUPT (1/0),
#   CCAGE_AUTOCK_NO_BYPASS_ACCEPT (1 = don't auto-accept the DSP bypass screen),
#   CCAGE_AUTOCK_EXEC (override the launched command; default `claude "$@"`),
#   CCAGE_AUTOCK_CHROME (1 = keep the Claude-in-Chrome handshake; default off,
#     i.e. launch adds --no-chrome — an autonomous session never drives a browser),
#   CCAGE_AUTOCK_INIT_PROMPT (type this + Enter at startup to auto-begin the task),
#   CCAGE_AUTOCK_INIT_DELAY (fallback ceiling, seconds, if the TUI ready-marker
#     never appears — normally the init prompt fires as soon as it does; default 20),
#   CCAGE_AUTOCK_READY_MARKER (string marking the TUI as rendered; default ❯),
#   CCAGE_AUTOCK_NUDGE (override the soft-nudge text; {pct}/{sentinel} substituted),
#   CCAGE_AUTOCK_HARD_NUDGE (override the hard-backstop nudge text; same substitutions),
#   CCAGE_AUTOCK_NUDGE_TIMEOUT (s before re-nudge if unconfirmed; default 600),
#   CCAGE_AUTOCK_COOLDOWN (s to ignore thresholds after a reset; default 30).
#   CCAGE_SLOT is honoured for RESUME naming.
#
# Context windows differ by model and the transcript does NOT record which window
# a session has (a 1M and a 200K session log the same model id). The window is
# resolved per measurement (so a mid-session /model switch is picked up), most
# specific first: --window/CCAGE_AUTOCK_WINDOW force > per-model map > a [1m]
# marker in the model id > built-in small families (haiku) > a 1,000,000 default.
# The one case the data can't disambiguate — a 200K vs 1M variant of the SAME
# family — is yours to pin via --window-map / CCAGE_AUTOCK_WINDOWS (or --window).

import errno
import fcntl
import glob
import json
import os
import pty
import re
import select
import shlex
import signal
import struct
import subprocess
import sys
import termios
import threading
import time
import tty

# ----------------------------------------------------------------------------
# Configuration
# ----------------------------------------------------------------------------

SENTINEL_DEFAULT = "CHECKPOINTED"

# The transcript does NOT record the context window: a 1M session logs its model
# as plain "claude-opus-4-8", identical to a 200K session. So we cannot infer the
# window from the model id. Default to 1,000,000 (the long-context variant these
# autonomous sessions run on) and let --window / CCAGE_AUTOCK_WINDOW override it
# down to 200000 for a standard-context session. Defaulting HIGH is the safe
# failure: at worst the watcher defers to the hard threshold / auto-compact,
# whereas defaulting LOW would make it fire spuriously early.
WINDOW_1M = 1_000_000
WINDOW_STD = 200_000
ONE_M_MARKERS = ("[1m]", "-1m", "_1m")
BUILTIN_SMALL = ("haiku",)    # families that are unambiguously 200K
DEFAULT_WINDOW = WINDOW_1M    # fallback when the model is unknown / ambiguous

# Timing constants (seconds). Conservative; the fragile part is slash-command
# entry, so we settle generously before pressing Enter.
KEY_DELAY = 0.25        # pause between typing a line and submitting it
CLEAR_SETTLE = 3.0      # wait after /clear for the SessionStart hook + reload
COOLDOWN = 30.0         # ignore thresholds for this long after a reset
NUDGE_TIMEOUT = 600.0   # if no checkpoint confirmation, re-nudge / escalate
MAX_RENUDGE = 1         # soft re-nudges before escalating to the hard path


def _truthy(v, default):
    if v is None:
        return default
    return str(v).strip().lower() not in ("0", "false", "no", "off", "")


def _num(v, default):
    try:
        return float(v)
    except (TypeError, ValueError):
        return default


def launch_command(cfg):
    """The shell command run_proxy hands to the interactive shell.
    CCAGE_AUTOCK_EXEC wins verbatim (a custom launcher owns its own flags);
    otherwise `claude`, with --no-chrome unless CCAGE_AUTOCK_CHROME opts back in.
    The disabled pass-through does NOT use this — it stays a transparent `claude`."""
    exec_override = os.environ.get("CCAGE_AUTOCK_EXEC")
    if exec_override:
        return exec_override
    return 'claude "$@"' if cfg.chrome else 'claude --no-chrome "$@"'


class Config:
    def __init__(self, args):
        self.enabled = _truthy(os.environ.get("CCAGE_AUTOCK"), True)
        self.soft = _num(os.environ.get("CCAGE_AUTOCK_SOFT"), 35.0)
        self.hard = _num(os.environ.get("CCAGE_AUTOCK_HARD"), 55.0)
        self.window = int(_num(os.environ.get("CCAGE_AUTOCK_WINDOW"), 0)) or None
        self.windows = parse_window_map(os.environ.get("CCAGE_AUTOCK_WINDOWS"))
        self.poll = _num(os.environ.get("CCAGE_AUTOCK_POLL"), 12.0)
        self.sentinel = os.environ.get("CCAGE_AUTOCK_SENTINEL") or SENTINEL_DEFAULT
        self.hard_interrupt = _truthy(os.environ.get("CCAGE_AUTOCK_HARD_INTERRUPT"), True)
        self.nudge_timeout = _num(os.environ.get("CCAGE_AUTOCK_NUDGE_TIMEOUT"), NUDGE_TIMEOUT)
        self.cooldown = _num(os.environ.get("CCAGE_AUTOCK_COOLDOWN"), COOLDOWN)
        # Autonomous kickoff: type this prompt + Enter once at startup so an
        # unattended session actually begins its task (a prompt passed as a CLI
        # arg only pre-fills the TUI input box; nobody is there to press Enter).
        self.init_prompt = os.environ.get("CCAGE_AUTOCK_INIT_PROMPT")
        # init_delay is now a FALLBACK CEILING: the kickoff normally fires as
        # soon as the TUI ready-marker is seen (measured 5–7s); only if the
        # marker never appears by the ceiling do we type blind (old behavior).
        self.init_delay = _num(os.environ.get("CCAGE_AUTOCK_INIT_DELAY"), 20.0)
        # First occurrence of this string in the ANSI-stripped pty output marks
        # the TUI input box as rendered. ❯ is the input prompt char; menus also
        # use it as a selection caret, so the bypass-accept path invalidates it.
        self.ready_marker = (os.environ.get("CCAGE_AUTOCK_READY_MARKER") or "❯").encode("utf-8")
        # Override the soft-nudge text; {pct} and {sentinel} are substituted.
        self.nudge = os.environ.get("CCAGE_AUTOCK_NUDGE")
        # Override the hard-backstop nudge text (same substitutions).
        self.hard_nudge = os.environ.get("CCAGE_AUTOCK_HARD_NUDGE")
        # Skip the Claude-in-Chrome startup handshake by default: an autonomous
        # session never drives a browser, and the connect attempt costs startup
        # time. CCAGE_AUTOCK_CHROME=1 keeps chrome (also the escape hatch for a
        # CLI too old to know --no-chrome, which would otherwise exit at launch).
        self.chrome = _truthy(os.environ.get("CCAGE_AUTOCK_CHROME"), False)
        self.status_only = False
        self.claude_args = self._parse(args)

    def _parse(self, args):
        i = 0

        def take():
            """The value token after the current flag, or None if the flag was
            last on the line — so a dangling `--soft` falls back to its default
            instead of raising IndexError."""
            return args[i + 1] if i + 1 < len(args) else None

        while i < len(args):
            a = args[i]
            if a == "--":
                return args[i + 1:]
            elif a == "--autock":
                self.enabled = True
            elif a == "--no-autock":
                self.enabled = False
            elif a == "--status":
                self.status_only = True
            elif a == "--soft":
                self.soft = _num(take(), self.soft); i += 1
            elif a == "--hard":
                self.hard = _num(take(), self.hard); i += 1
            elif a == "--window":
                self.window = int(_num(take(), self.window or 0)) or None; i += 1
            elif a == "--window-map":
                self.windows.update(parse_window_map(take())); i += 1
            elif a == "--poll":
                self.poll = _num(take(), self.poll); i += 1
            else:
                # First token we don't recognise: the rest is claude's.
                return args[i:]
            i += 1
        return []

    def window_for(self, model):
        """Resolve the context window for a model id, most specific first:
        global override -> per-model map -> [1m] marker in the id -> built-in
        small family (haiku) -> default. Called per measurement, so a mid-session
        /model switch re-resolves the window automatically."""
        if self.window:
            return self.window
        if model:
            for key, win in self.windows.items():
                if key in model:
                    return win
            if any(m in model for m in ONE_M_MARKERS):
                return WINDOW_1M
            if any(s in model for s in BUILTIN_SMALL):
                return WINDOW_STD
        return DEFAULT_WINDOW

    def validate(self):
        """Clamp nonsensical thresholds; return human-readable warnings."""
        self.soft, self.hard, warns = clamp_thresholds(self.soft, self.hard)
        return warns


def clamp_thresholds(soft, hard):
    """Clamp a (soft, hard) threshold pair to sane values; return
    (soft, hard, warnings). Shared by Config.validate (launch flags/env), the
    `--set` control command, and the watcher's live control-file re-read so the
    exact same rules — ranges plus soft < hard — apply everywhere."""
    warns = []
    if not (0 < soft < 100):
        warns.append("soft=%.0f out of range (0,100); using 35" % soft)
        soft = 35.0
    if not (0 < hard <= 100):
        warns.append("hard=%.0f out of range (0,100]; using 55" % hard)
        hard = 55.0
    if soft >= hard:
        new_hard = min(100.0, soft + 10)   # cap at 100, never <= soft
        warns.append("soft (%.0f%%) >= hard (%.0f%%); raising hard to %.0f%%"
                     % (soft, hard, new_hard))
        hard = new_hard
    return soft, hard, warns


# ----------------------------------------------------------------------------
# Locating the cage transcript
# ----------------------------------------------------------------------------

def cwd_slug(path):
    """Claude's project-dir slug: every non-alphanumeric cwd char becomes '-'.

    Not just '/' — '_' and '.' convert too (verified against real projects/
    dirs). Getting this wrong means watching an empty dir and never firing.
    """
    return re.sub(r"[^A-Za-z0-9]", "-", path)


def slot_suffix():
    """Mirror claude-isolation.sh's CCAGE_SLOT validation for RESUME naming."""
    slot = os.environ.get("CCAGE_SLOT", "")
    if slot and re.fullmatch(r"[A-Za-z0-9_-]+", slot):
        return "." + slot
    return ""


def resolve_config_dir(cwd):
    """Return the cage's CLAUDE_CONFIG_DIR for this cwd.

    Faithfulness matters (a companion override file can change the choice), so we
    ask ccage's own shell function first via the user's interactive shell, then
    fall back to sourcing the library directly, then to a pure-Python replica of
    the default naming (sans the rare collision hash)."""
    shell = os.environ.get("SHELL", "/bin/bash")

    # 0. Fast path: inside a cage, CLAUDE_CONFIG_DIR is already exported into every
    #    subprocess (the wrapper sets it for the launched session), so a nested
    #    `ccage-auto --status` invoked from the session's own Bash — the common
    #    case for the /checkpoint-threshold skill — inherits the authoritative
    #    value. Using it directly skips the ~2s interactive-shell resolution
    #    below (which sources the full .bashrc, conda init and all). It is unset
    #    when ccage-auto is the launcher (the watcher resolves the dir at startup
    #    before it launches claude), so the shell/replica fallbacks still apply
    #    there — where the override-faithful interactive path matters.
    cc = os.environ.get("CLAUDE_CONFIG_DIR")
    if cc:
        return cc

    # 1. Ask the real function through an interactive shell (sees .bashrc + overrides).
    try:
        out = subprocess.run(
            [shell, "-ic", '_ccage_config_dir_for "$PWD" 2>/dev/null'],
            cwd=cwd, capture_output=True, text=True, timeout=15,
        ).stdout.strip()
        if out:
            return out.splitlines()[-1].strip()
    except Exception:
        pass

    # 2. Source the shipped library directly (no interactive init).
    lib = library_path()
    if lib:
        try:
            out = subprocess.run(
                [shell, "-c", f'. {shlex.quote(lib)}; _ccage_config_dir_for "$PWD"'],
                cwd=cwd, capture_output=True, text=True, timeout=15,
            ).stdout.strip()
            if out:
                return out.splitlines()[-1].strip()
        except Exception:
            pass

    # 3. Pure-Python replica of the default scheme.
    root = os.environ.get("CCAGE_ROOT", os.path.expanduser("~"))
    prefix = os.environ.get("CCAGE_PREFIX", ".claude-")
    base = os.path.basename(cwd.rstrip("/")) or "root"
    cand = os.path.join(root, prefix + base)
    slot = os.environ.get("CCAGE_SLOT", "")
    if slot and re.fullmatch(r"[A-Za-z0-9_-]+", slot):
        cand += "--" + slot
    return cand


def library_path():
    """share/claude-isolation.sh, resolved relative to this script or $CCAGE_LIB."""
    candidates = []
    if os.environ.get("CCAGE_LIB"):
        candidates.append(os.environ["CCAGE_LIB"])
    here = os.path.dirname(os.path.realpath(__file__))
    candidates += [os.path.join(here, "..", "share"),
                   os.path.join(here, "..", "share", "ccage")]
    for c in candidates:
        p = os.path.join(c, "claude-isolation.sh")
        if os.path.isfile(p):
            return os.path.realpath(p)
    return None


def session_dir(config_dir, cwd):
    return os.path.join(config_dir, "projects", cwd_slug(cwd))


def active_jsonl(sdir):
    """Newest transcript in the session dir (handles /clear rotating the file).
    Stats each candidate defensively: a file can be rotated/deleted between the
    glob and the stat, and an unguarded getmtime there would crash the watcher
    thread."""
    best, best_mtime = None, -1.0
    for f in glob.glob(os.path.join(sdir, "*.jsonl")):
        try:
            m = os.path.getmtime(f)
        except OSError:
            continue
        if m > best_mtime:
            best, best_mtime = f, m
    return best


# ----------------------------------------------------------------------------
# Reading context occupancy from the transcript
# ----------------------------------------------------------------------------

def _tail(path, maxbytes=512 * 1024):
    try:
        with open(path, "rb") as f:
            f.seek(0, os.SEEK_END)
            size = f.tell()
            start = max(0, size - maxbytes)
            f.seek(start)
            data = f.read()
    except OSError:
        return []
    if start > 0:
        nl = data.find(b"\n")
        data = data[nl + 1:] if nl >= 0 else b""
    return data.split(b"\n")


def latest_usage(path):
    """(tokens, model) for the most recent assistant turn, or (None, None).

    tokens = input + cache_read + cache_creation = the size of the prompt the
    model was just sent = current context occupancy."""
    for line in reversed(_tail(path)):
        line = line.strip()
        if not line or b'"assistant"' not in line:
            continue
        try:
            obj = json.loads(line)
        except ValueError:
            continue
        if obj.get("type") != "assistant":
            continue
        msg = obj.get("message") or {}
        usage = msg.get("usage") or {}
        if "input_tokens" not in usage:
            continue
        tokens = (
            (usage.get("input_tokens") or 0)
            + (usage.get("cache_read_input_tokens") or 0)
            + (usage.get("cache_creation_input_tokens") or 0)
        )
        return tokens, msg.get("model")
    return None, None


def parse_window_map(spec):
    """Parse a 'substr=tokens,substr=tokens' per-model window map into a dict.

    Keys are matched as substrings of the transcript model id (e.g.
    'haiku=200000,opus=1000000'). Malformed entries are ignored."""
    out = {}
    if not spec:
        return out
    for entry in spec.split(","):
        entry = entry.strip()
        if "=" not in entry:
            continue
        key, _, val = entry.partition("=")
        key = key.strip()
        try:
            n = int(val.strip())
        except ValueError:
            continue
        if key and n > 0:
            out[key] = n
    return out


def resume_mtime(cwd):
    """Newest mtime among RESUME.md / RESUME.<slot>.md, or 0."""
    best = 0.0
    for name in ("RESUME.md", "RESUME%s.md" % slot_suffix()):
        p = os.path.join(cwd, name)
        if os.path.isfile(p):
            best = max(best, os.path.getmtime(p))
    return best


# The completion marker written by `/checkpoint --final` (see the checkpoint
# skill). Deliberately a single fixed name, not slot-scoped: a coarse
# "the session's work is done, helpers may stand down" signal for this directory.
SESSION_DONE_MARKER = ".ccage-session-done"


def session_done_mtime(cwd):
    """mtime of the .ccage-session-done marker in cwd, or 0 if absent."""
    p = os.path.join(cwd, SESSION_DONE_MARKER)
    try:
        return os.path.getmtime(p)
    except OSError:
        return 0.0


# The live control file, written by the /checkpoint-threshold skill (or by
# `ccage-auto --set/--pause/--resume/--reset`). A running watcher re-reads it
# every poll, so the soft/hard thresholds and a pause switch can be changed
# mid-session with no restart. Deliberately in cwd (where the session's own Bash
# runs and where the watcher already looks for the done-marker) and NOT
# slot-scoped: it's a coarse per-directory override for this one run. The
# SessionStart hook clears it on a genuinely new session (startup/resume) so a
# stale override never carries over — but it survives ccage-auto's own /clear
# (source=clear), which is the whole point.
AUTOCK_CONF = ".ccage-autock.conf"


def control_path(cwd):
    return os.path.join(cwd, AUTOCK_CONF)


def read_control_file(cwd):
    """Parse the control file into {'soft': float, 'hard': float, 'paused': bool}.

    Only keys actually present are returned; blank/`#`/malformed lines and
    unparseable values are ignored, so a half-written file (the watcher may read
    it mid-write) degrades to 'no override' rather than crashing the thread."""
    out = {}
    try:
        with open(control_path(cwd)) as f:
            raw = f.read()
    except OSError:
        return out
    for line in raw.splitlines():
        line = line.strip()
        if not line or line.startswith("#") or "=" not in line:
            continue
        key, _, val = line.partition("=")
        key = key.strip().lower()
        val = val.strip()
        if key in ("soft", "hard"):
            try:
                out[key] = float(val)
            except ValueError:
                pass
        elif key == "paused":
            out[key] = val.lower() not in ("0", "false", "no", "off", "")
    return out


def _git_exclude(cwd, name):
    """Best-effort: add `name` to this repo's .git/info/exclude (like the
    done-marker and RESUME), so the control file never shows up as untracked.
    A no-op outside a git repo or if anything fails."""
    try:
        gd = subprocess.run(["git", "rev-parse", "--git-dir"], cwd=cwd,
                            capture_output=True, text=True, timeout=5).stdout.strip()
    except Exception:
        return
    if not gd:
        return
    if not os.path.isabs(gd):
        gd = os.path.join(cwd, gd)
    ex = os.path.join(gd, "info", "exclude")
    try:
        os.makedirs(os.path.dirname(ex), exist_ok=True)
        existing = ""
        if os.path.isfile(ex):
            with open(ex) as f:
                existing = f.read()
        if name not in existing.split():
            with open(ex, "a") as f:
                f.write(name + "\n")
    except OSError:
        pass


def write_control_file(cwd, updates):
    """Merge `updates` into the control file and rewrite it. A key whose value is
    None is removed. Returns the resulting dict. Idempotently git-excludes the
    file. Note: this does NOT clamp — callers (`--set`) validate first so the
    user sees any warning; the watcher re-clamps on read as a backstop."""
    cur = read_control_file(cwd)
    for k, v in updates.items():
        if v is None:
            cur.pop(k, None)
        else:
            cur[k] = v
    lines = [
        "# ccage-auto live control file — written by /checkpoint-threshold.",
        "# A running watcher re-reads this each poll; it is cleared at the next",
        "# session start. For a permanent change use --soft/--hard or",
        "# CCAGE_AUTOCK_SOFT/CCAGE_AUTOCK_HARD at launch.",
    ]
    if "soft" in cur:
        lines.append("soft=%g" % float(cur["soft"]))
    if "hard" in cur:
        lines.append("hard=%g" % float(cur["hard"]))
    if "paused" in cur:
        lines.append("paused=%d" % (1 if cur["paused"] else 0))
    with open(control_path(cwd), "w") as f:
        f.write("\n".join(lines) + "\n")
    _git_exclude(cwd, AUTOCK_CONF)
    return cur


# ----------------------------------------------------------------------------
# The watcher (runs in a thread; injects by writing to the pty master fd)
# ----------------------------------------------------------------------------

class Watcher:
    # states
    NORMAL = "normal"
    NUDGED = "nudged"
    COOLDOWN = "cooldown"

    def __init__(self, cfg, master_fd, write_lock, cwd, sdir, logf):
        self.cfg = cfg
        self.fd = master_fd
        self.lock = write_lock
        self.cwd = cwd
        self.sdir = sdir
        self.log = logf
        self.state = self.NORMAL
        self.stop = False
        # Launch-time thresholds, kept so the live control file can be *removed*
        # (or a key dropped) and we revert to exactly what the run started with —
        # not to the built-in defaults.
        self.base_soft = cfg.soft
        self.base_hard = cfg.hard
        self.paused = False        # set by a `paused=1` control file
        self.conf_mtime = -1.0     # last-seen mtime of the control file
        # A `.ccage-session-done` marker newer than this counts as "this run's
        # work is finished." Anchoring on start time means a stale marker from a
        # previous run (which the SessionStart hook also clears at startup) can
        # never trip an immediate stand-down before any work has happened.
        self.start_time = time.time()
        self.tui_ready = threading.Event()
        self.nudge_at = 0.0
        self.nudge_offset = 0     # transcript byte offset at nudge time
        self.nudge_path = None    # transcript file current at nudge time
        self.renudges = 0
        self.hard_fired = False   # hard-threshold escalation done for this cycle
        self.cooldown_until = 0.0
        self.last_path = None     # transcript path of the last occupancy reading
        self.last_sz = -1         # size of that transcript at the last reading
        self.last_tokens = None   # assistant tokens at the last reading
        self.last_pct = None      # last measured occupancy %, reused between turns

    def _log(self, msg):
        try:
            self.log.write("%s  %s\n" % (time.strftime("%H:%M:%S"), msg))
            self.log.flush()
        except Exception:
            pass

    def _write(self, data):
        """Write to the pty master, tolerating the child having exited.

        If the session has gone away mid-injection the fd is closed/broken; treat
        that as a stop signal rather than letting the watcher thread die on an
        unhandled OSError."""
        try:
            os.write(self.fd, data)
            return True
        except OSError:
            self.stop = True
            return False

    def _type(self, text, submit=True, settle=KEY_DELAY):
        with self.lock:
            if not self._write(text.encode()):
                return
            if submit:
                time.sleep(settle)
                self._write(b"\r")

    def _interrupt(self):
        # Escape interrupts a running turn (forces the model to yield) and also
        # dismisses any open autocomplete menu when the prompt is idle.
        with self.lock:
            self._write(b"\x1b")
        time.sleep(0.5)

    def _soft_nudge(self, pct):
        if self.cfg.nudge:
            msg = self.cfg.nudge.replace("{pct}", "%.0f" % pct).replace("{sentinel}", self.cfg.sentinel)
        else:
            # Advisory, not an order: the model weighs the cost. It may hold off if
            # checkpointing now would lose in-flight work (a running subagent, a
            # mid-edit) — the hard threshold below is the real deadline.
            msg = (
                "[auto-checkpoint] Context is at %.0f%% of the window — a good moment "
                "to checkpoint soon, but use your judgment; prioritise not losing "
                "work. If a subagent is still running, or you are mid-task where "
                "clearing now would drop in-flight results, finish that first. When "
                "you reach a clean breakpoint (never interrupt an in-progress edit or "
                "a running subagent), invoke the checkpoint skill to update "
                "RESUME.md, then print the single token %s on its own line and stop; "
                "this session is then cleared and resumed from RESUME.md "
                "automatically. If now is a bad moment, hold off — you will be "
                "reminded, and a hard backstop fires before the window fills." % (pct, self.cfg.sentinel)
            )
        self._type(msg)

    def _hard_nudge(self, pct):
        if self.cfg.hard_nudge:
            msg = self.cfg.hard_nudge.replace("{pct}", "%.0f" % pct).replace("{sentinel}", self.cfg.sentinel)
        else:
            # The backstop: past here, auto-compact is near and would lose more
            # than a checkpoint. Still respect a running subagent (wait for it),
            # but do not defer beyond that.
            msg = (
                "[auto-checkpoint] Context is at %.0f%% — the hard backstop. "
                "Auto-compact is close and would lose more than a checkpoint does, "
                "so wrap up at the very next safe point: if a subagent is running, "
                "wait for it to return, then immediately invoke the checkpoint skill "
                "to update RESUME.md, print %s on its own line, and stop. Do not "
                "start new work." % (pct, self.cfg.sentinel)
            )
        self._type(msg)

    def _arm_nudge(self, path, pct, hard=False):
        """Stamp the nudge time + the transcript file/offset, then type the soft
        (advisory) or hard (backstop) nudge. We pin the *file* current at nudge
        time (not just the offset): the model echoes the sentinel into it before
        we /clear rotates to a new file, so scanning that pinned file keeps
        confirmation correct across rotation."""
        self.nudge_at = time.time()
        self.nudge_path = path
        self.nudge_offset = os.path.getsize(path)
        if hard:
            self._hard_nudge(pct)
        else:
            self._soft_nudge(pct)

    def _refresh_control(self):
        """Re-read the live control file (mtime-gated) and apply soft/hard/paused
        over the launch baseline. An absent file or a dropped key reverts to the
        launch value. Clamped with the same rules as the launch flags."""
        try:
            mt = os.path.getmtime(control_path(self.cwd))
        except OSError:
            mt = 0.0
        if mt == self.conf_mtime:
            return
        self.conf_mtime = mt
        ov = read_control_file(self.cwd) if mt else {}
        soft, hard, _ = clamp_thresholds(ov.get("soft", self.base_soft),
                                         ov.get("hard", self.base_hard))
        paused = bool(ov.get("paused", False))
        if (soft != self.cfg.soft or hard != self.cfg.hard or paused != self.paused):
            self._log("control update: soft=%.0f%% hard=%.0f%% paused=%s"
                      % (soft, hard, paused))
        self.cfg.soft = soft
        self.cfg.hard = hard
        if paused != self.paused:
            self.paused = paused
            if not paused:
                # Un-pausing: re-arm from a clean slate so occupancy re-triggers.
                self.state = self.NORMAL

    def _do_clear(self):
        self._interrupt()                # dismiss any menu / ensure clean line
        self._type("/clear", settle=KEY_DELAY)
        time.sleep(CLEAR_SETTLE)         # let SessionStart:clear reload RESUME
        self._type("Resume the task from RESUME.md — continue from the ### Next "
                   "section. Do not re-do completed work.")

    def _new_text_since_nudge(self):
        """Assistant text appended to the pinned nudge-time transcript after the
        nudge, for sentinel detection."""
        if not self.nudge_path:
            return ""
        try:
            with open(self.nudge_path, "rb") as f:
                f.seek(self.nudge_offset)
                data = f.read()
        except OSError:
            return ""
        out = []
        for line in data.split(b"\n"):
            if b'"assistant"' not in line:
                continue
            try:
                obj = json.loads(line)
            except ValueError:
                continue
            if obj.get("type") != "assistant":
                continue
            for blk in (obj.get("message") or {}).get("content") or []:
                if isinstance(blk, dict) and blk.get("type") == "text":
                    out.append(blk.get("text", ""))
        return "\n".join(out)

    def _confirmed(self):
        seen = self.cfg.sentinel in self._new_text_since_nudge()
        resume_fresh = resume_mtime(self.cwd) > self.nudge_at
        # Sentinel is primary; RESUME freshness corroborates.
        if seen and resume_fresh:
            return True
        if seen and (time.time() - self.nudge_at) > 20:
            return True
        return False

    def run(self):
        cfg = self.cfg
        self._log("watcher start: soft=%.0f%% hard=%.0f%% poll=%.0fs"
                  % (cfg.soft, cfg.hard, cfg.poll))
        # Autonomous kickoff: submit the initial task once the TUI is ready (after
        # any bypass-permissions accept). Without this an unattended session idles
        # at an empty prompt and never produces work to manage.
        if cfg.init_prompt and not self.stop:
            deadline = time.time() + cfg.init_delay
            while not self.stop:
                remaining = deadline - time.time()
                if remaining <= 0:
                    self._log("ready-marker not seen after %.0fs — typing init prompt anyway"
                              % cfg.init_delay)
                    break
                if self.tui_ready.wait(timeout=min(remaining, 0.5)):
                    time.sleep(1.0)          # settle: let the frame finish painting
                    if self.tui_ready.is_set():   # not invalidated by bypass-accept
                        self._log("TUI ready after %.1fs — sending init prompt"
                                  % (cfg.init_delay - remaining + 1.0))
                        break
            if not self.stop:
                self._type(cfg.init_prompt)
        while not self.stop:
            time.sleep(cfg.poll)
            # Stand down the moment the session is marked done (/checkpoint
            # --final). ccage-auto is a persistent process that owns the /clear
            # cycles, so — unlike /keepwarm — it reads the marker with no
            # /clear-survival caveat: this is the load-bearing consumer. Standing
            # down stops the nudge/clear state machine but leaves the claude
            # session itself running for the user.
            if session_done_mtime(self.cwd) > self.start_time:
                self._log("session marked done (%s) — standing down; "
                          "no more nudges/clears" % SESSION_DONE_MARKER)
                self.stop = True
                break
            # Live thresholds / pause (mid-session /checkpoint-threshold). Read
            # every poll but re-parsed only when the file's mtime changes.
            self._refresh_control()
            if self.paused:
                # Suspended: no nudges/clears. We keep polling so a `resume`
                # (and the done-marker) are still seen promptly.
                continue
            path = active_jsonl(self.sdir)
            if not path:
                continue

            try:
                sz = os.path.getsize(path)
            except OSError:
                continue

            # Re-measure occupancy only when the active transcript changed or grew,
            # and only treat a changed token count as a fresh reading — growth from
            # user typing or a logged /clear keeps the last pct. Skipping the
            # *re-parse* must never skip the state machine below: a stalled or
            # idle-over-threshold session still has to be nudged, re-nudged, and
            # hard-interrupted on the timed cadence even while nothing new is logged.
            if path != self.last_path:
                self.last_path = path
                self.last_sz = -1
                self.last_tokens = None
                self.last_pct = None
            if sz != self.last_sz:
                self.last_sz = sz
                tokens, model = latest_usage(path)
                if tokens is not None and tokens != self.last_tokens:
                    self.last_tokens = tokens
                    self.last_pct = 100.0 * tokens / cfg.window_for(model)

            if self.last_pct is None or self.last_tokens is None:
                continue
            tokens = self.last_tokens
            pct = self.last_pct

            if self.state == self.COOLDOWN:
                if time.time() >= self.cooldown_until and pct < cfg.soft:
                    self._log("reset complete (%.1f%%); back to NORMAL" % pct)
                    self.state = self.NORMAL
                continue

            if self.state == self.NORMAL:
                if pct >= cfg.soft:
                    self._log("soft threshold hit at %.1f%% (%d tok) — nudging" % (pct, tokens))
                    self.renudges = 0
                    self.hard_fired = False
                    self._arm_nudge(path, pct)
                    self.state = self.NUDGED
                continue

            if self.state == self.NUDGED:
                if self._confirmed():
                    self._log("checkpoint confirmed at %.1f%% — clearing" % pct)
                    self._do_clear()
                    self.cooldown_until = time.time() + cfg.cooldown
                    self.state = self.COOLDOWN
                elif pct >= cfg.hard and not self.hard_fired:
                    # Fire the forceful escalation ONCE per nudge cycle. Re-firing
                    # every poll would re-interrupt the model mid-checkpoint and
                    # keep resetting nudge_at, so the timed fallbacks in
                    # _confirmed() could never accumulate. After this, fall through
                    # to the nudge_timeout cadence below.
                    self._log("HARD threshold at %.1f%% — forcing checkpoint" % pct)
                    if cfg.hard_interrupt:
                        self._interrupt()
                    self.hard_fired = True
                    self._arm_nudge(path, pct, hard=True)
                elif (time.time() - self.nudge_at) > cfg.nudge_timeout:
                    if self.renudges < MAX_RENUDGE:
                        self.renudges += 1
                        self._log("no checkpoint after %.0fs — re-nudging" % cfg.nudge_timeout)
                        self._arm_nudge(path, pct)
                    else:
                        self._log("re-nudge exhausted — interrupting + nudging")
                        if cfg.hard_interrupt:
                            self._interrupt()
                        self._arm_nudge(path, pct, hard=True)
                        self.renudges = 0


# ----------------------------------------------------------------------------
# pty proxy
# ----------------------------------------------------------------------------

def set_winsize(fd):
    try:
        sz = fcntl.ioctl(0, termios.TIOCGWINSZ, b"\x00" * 8)
        fcntl.ioctl(fd, termios.TIOCSWINSZ, sz)
    except OSError:
        pass


def run_proxy(cfg, cwd, sdir, logpath):
    shell = os.environ.get("SHELL", "/bin/bash")
    # CCAGE_AUTOCK_EXEC overrides the command launched inside the pty (default the
    # cage's `claude` shell function). For custom launchers and for testing.
    launch = launch_command(cfg)
    child_argv = [shell, "-ic", launch, shell] + cfg.claude_args

    pid, master_fd = pty.fork()
    if pid == 0:  # child: becomes the cage's claude session
        os.execvp(shell, child_argv)
        os._exit(127)

    set_winsize(master_fd)

    # raw mode on our stdin so keystrokes pass straight through to the TUI
    try:
        old_attr = termios.tcgetattr(0)
        tty.setraw(0)
        raw = True
    except termios.error:
        old_attr = None
        raw = False

    write_lock = threading.Lock()
    logf = open(logpath, "a", buffering=1)
    watcher = Watcher(cfg, master_fd, write_lock, cwd, sdir, logf)
    if cfg.enabled:
        t = threading.Thread(target=watcher.run, daemon=True)
        t.start()

    signal.signal(signal.SIGWINCH, lambda *_: set_winsize(master_fd))

    # A --dangerously-skip-permissions launch in a not-yet-accepted cage opens on
    # a "Bypass Permissions mode" screen defaulting to "No, exit" — an unattended
    # session would hang there. Since the user opted into DSP, auto-accept it
    # (Down -> "Yes, I accept" -> Enter). Opt out with CCAGE_AUTOCK_NO_BYPASS_ACCEPT.
    ANSI = re.compile(rb'\x1b\[[0-9;?]*[a-zA-Z]|\x1b[()][AB0]|\x1b\][^\x07]*\x07|[\x00-\x08\x0e-\x1f]')
    out_buf = b""
    bypass_done = bool(os.environ.get("CCAGE_AUTOCK_NO_BYPASS_ACCEPT"))
    started = time.time()

    stdin_ok = True
    try:
        while True:
            watch = [master_fd] + ([0] if stdin_ok else [])
            try:
                rfds, _, _ = select.select(watch, [], [])
            except select.error as e:
                if e.args[0] == errno.EINTR:
                    continue
                raise
            if master_fd in rfds:
                try:
                    data = os.read(master_fd, 65536)
                except OSError:
                    break
                if not data:
                    break
                os.write(1, data)
                # Scan only while something still needs detecting: the bypass
                # screen (60s window) or TUI readiness (until found or the
                # kickoff ceiling + slack lapses) — never for the whole session.
                elapsed = time.time() - started
                scan_window = elapsed < 60
                ready_window = elapsed < max(60.0, cfg.init_delay + 5.0)
                if (not watcher.tui_ready.is_set() and ready_window) or (not bypass_done and scan_window):
                    out_buf = ANSI.sub(b"", out_buf + data)[-4096:]
                    # Match the screen's distinctive title AND its accept-option
                    # label, not the bare words "Bypass"/"accept" — those occur in
                    # ordinary repo content (changelogs, licences) and a loose
                    # match could fire a spurious Down+Enter into the live TUI.
                    if not bypass_done and scan_window and \
                       b"Bypass Permissions" in out_buf and b"Yes, I accept" in out_buf:
                        with write_lock:
                            os.write(master_fd, b"\x1b[B")   # down -> "Yes, I accept"
                            time.sleep(0.3)
                            os.write(master_fd, b"\r")        # confirm
                        bypass_done = True
                        # The bypass menu renders ❯ as its selection caret — any
                        # readiness inferred from that screen is false. Reset;
                        # the real TUI frame after acceptance re-sets it.
                        out_buf = b""
                        watcher.tui_ready.clear()
                        logf.write("%s  auto-accepted bypass-permissions prompt\n"
                                   % time.strftime("%H:%M:%S"))
                        logf.flush()
                    elif not watcher.tui_ready.is_set() and cfg.ready_marker in out_buf:
                        watcher.tui_ready.set()
                        logf.write("%s  TUI ready-marker seen (%.1fs after launch)\n"
                                   % (time.strftime("%H:%M:%S"), time.time() - started))
                        logf.flush()
            if stdin_ok and 0 in rfds:
                try:
                    data = os.read(0, 65536)
                except OSError:
                    data = b""
                if not data:
                    # stdin hit EOF (non-tty / closed): stop polling it so we don't
                    # busy-spin; the child runs on under watcher control.
                    stdin_ok = False
                else:
                    with write_lock:
                        os.write(master_fd, data)
    finally:
        watcher.stop = True
        if raw and old_attr is not None:
            termios.tcsetattr(0, termios.TCSADRAIN, old_attr)
        try:
            logf.close()
        except Exception:
            pass

    _, status = os.waitpid(pid, 0)
    return os.waitstatus_to_exitcode(status)


# ----------------------------------------------------------------------------
# main
# ----------------------------------------------------------------------------

def control_command(argv):
    """Handle the control-plane subcommands (--set/--pause/--resume/--reset) that
    the /checkpoint-threshold skill uses to talk to a running watcher: write the
    live control file for cwd and exit. Separate from launch so it never spawns a
    session. Returns a process exit code."""
    cwd = os.getcwd()
    action = argv[0]

    if action == "--reset":
        try:
            os.remove(control_path(cwd))
            print("ccage-auto: control file cleared — reverting to launch thresholds")
        except OSError:
            print("ccage-auto: no control file to reset (already at launch thresholds)")
        return 0

    if action == "--pause":
        write_control_file(cwd, {"paused": True})
        print("ccage-auto: auto-checkpoint PAUSED (say resume to re-enable)")
        return 0

    if action == "--resume":
        write_control_file(cwd, {"paused": False})
        print("ccage-auto: auto-checkpoint resumed")
        return 0

    # --set: one or more key=value tokens (space- or comma-separated).
    updates = {}
    for tok in argv[1:]:
        for pair in tok.split(","):
            pair = pair.strip()
            if not pair:
                continue
            if "=" not in pair:
                sys.stderr.write("[ccage-auto] ignored '%s' (want key=value)\n" % pair)
                continue
            k, _, v = pair.partition("=")
            k = k.strip().lower()
            v = v.strip()
            if k not in ("soft", "hard", "paused"):
                sys.stderr.write("[ccage-auto] ignored unknown key '%s'\n" % k)
                continue
            if k == "paused":
                updates[k] = v.lower() not in ("0", "false", "no", "off", "")
                continue
            try:
                updates[k] = float(v)
            except ValueError:
                sys.stderr.write("[ccage-auto] ignored %s=%s (not a number)\n" % (k, v))
    if not updates:
        sys.stderr.write("[ccage-auto] --set: nothing to set (usage: --set soft=50 [hard=65])\n")
        return 2
    # Validate against the *merged* view so a lone `soft` is checked against the
    # existing/launch `hard` too, and the user sees any clamp message now.
    merged = dict(read_control_file(cwd))
    merged.update(updates)
    if "soft" in merged and "hard" in merged:
        s, h, warns = clamp_thresholds(merged["soft"], merged["hard"])
        for w in warns:
            sys.stderr.write("[ccage-auto] %s\n" % w)
        if "soft" in updates:
            updates["soft"] = s
        if "hard" in updates:
            updates["hard"] = h
    result = write_control_file(cwd, updates)
    parts = []
    if "soft" in result:
        parts.append("soft=%g%%" % result["soft"])
    if "hard" in result:
        parts.append("hard=%g%%" % result["hard"])
    if result.get("paused"):
        parts.append("PAUSED")
    print("ccage-auto: control file updated — %s" % (", ".join(parts) or "(empty)"))
    print("            takes effect within one poll if a watcher is running here.")
    return 0


def print_status(cfg, cwd, config_dir, sdir):
    path = active_jsonl(sdir)
    print("ccage-auto status")
    print("  cwd          :", cwd)
    print("  config dir   :", config_dir)
    print("  session dir  :", sdir, "(exists)" if os.path.isdir(sdir) else "(missing)")
    print("  enabled      :", cfg.enabled)
    print("  launch       :", launch_command(cfg))
    print("  ready marker :", "%s (ceiling %.0fs)" % (cfg.ready_marker.decode("utf-8"), cfg.init_delay))
    print("  soft / hard  : %.0f%% / %.0f%% (launch)" % (cfg.soft, cfg.hard))
    ov = read_control_file(cwd)
    if ov:
        eff_soft, eff_hard, _ = clamp_thresholds(ov.get("soft", cfg.soft),
                                                 ov.get("hard", cfg.hard))
        parts = []
        if "soft" in ov:
            parts.append("soft=%g%%" % ov["soft"])
        if "hard" in ov:
            parts.append("hard=%g%%" % ov["hard"])
        if "paused" in ov:
            parts.append("paused=%s" % ov["paused"])
        print("  control file :", control_path(cwd))
        print("  overrides    :", ", ".join(parts))
        print("  effective    : %.0f%% / %.0f%%%s"
              % (eff_soft, eff_hard, "  (PAUSED)" if ov.get("paused") else ""))
    else:
        print("  control file : none (using launch thresholds)")
    if not path:
        print("  transcript   : none found")
        return
    tokens, model = latest_usage(path)
    window = cfg.window_for(model)
    print("  transcript   :", os.path.basename(path))
    print("  model        :", model)
    print("  window       :", window)
    if tokens is None:
        print("  occupancy    : no assistant turn with usage yet")
    else:
        print("  occupancy    : %d tok = %.1f%% of window" % (tokens, 100.0 * tokens / window))


def main():
    argv = sys.argv[1:]
    # Control-plane subcommands (used by /checkpoint-threshold): mutate the live
    # control file for cwd and exit without launching a session.
    if argv and argv[0] in ("--set", "--pause", "--resume", "--reset"):
        return control_command(argv)

    cfg = Config(argv)
    for w in cfg.validate():
        sys.stderr.write("[ccage-auto] %s\n" % w)
    cwd = os.getcwd()
    config_dir = resolve_config_dir(cwd)
    sdir = session_dir(config_dir, cwd)

    if cfg.status_only:
        print_status(cfg, cwd, config_dir, sdir)
        return 0

    if not cfg.enabled:
        # Transparent pass-through: behave exactly like launching `claude`.
        sys.stderr.write("[ccage-auto] disabled — launching normally\n")
        shell = os.environ.get("SHELL", "/bin/bash")
        launch = os.environ.get("CCAGE_AUTOCK_EXEC") or 'claude "$@"'
        os.execvp(shell, [shell, "-ic", launch, shell] + cfg.claude_args)
        return 127

    logpath = os.path.join(config_dir, "ccage-autock.log") \
        if os.path.isdir(config_dir) else os.path.join(cwd, ".ccage-autock.log")
    sys.stderr.write(
        "[ccage-auto] auto-checkpoint on — soft %.0f%% / hard %.0f%%, log: %s\n"
        % (cfg.soft, cfg.hard, logpath)
    )
    return run_proxy(cfg, cwd, sdir, logpath)


if __name__ == "__main__":
    try:
        sys.exit(main())
    except KeyboardInterrupt:
        sys.exit(130)
