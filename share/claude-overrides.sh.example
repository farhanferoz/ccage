# shellcheck shell=bash disable=SC2034
# ccage user overrides — copy to ~/.bashrc.d/claude-overrides.sh and edit.
#
# Loaded *after* claude-isolation.sh (alphabetical order), so the hook
# redefinitions below replace the stubs.
#
# Delete anything you don't use.

# ---- Pin specific paths to specific config dirs ----
# Useful when a worktree has a long unhelpful basename, or when you want two
# repos to share a config dir on purpose.
#
# IMPORTANT: after defining this function, set _CCAGE_OVERRIDE_ACTIVE=1 so
# ccage calls it. Without that flag, the override is never invoked.
_ccage_config_dir_override() {
    case "$1" in
        # /home/me/dev/work/project-aabbcc) echo "$HOME/.claude-project"; return 0 ;;
        # /home/me/dev/work/project-aabbcc/*) echo "$HOME/.claude-project-sub-${1##*/}"; return 0 ;;
    esac
    return 1
}
_CCAGE_OVERRIDE_ACTIVE=1

# ---- Per-PWD env, CLI args, and UI-only settings seeding ----
# Runs after the config dir is bootstrapped, just before `command claude`.
#
# DO: export env vars, append to _ccage_extra_args, seed UI keys (statusLine,
# theme) into $2/settings.json.
# DON'T: copy permissions, plugins, credentials, or any state from a shared
# master dir. That re-creates the cross-session cache-bashing ccage exists
# to prevent.
_ccage_pre_exec_hook() {
    local pwd_arg="$1"
    local config_dir="$2"

    # Example 1: inject plugin channels per worktree.
    # case "$pwd_arg" in
